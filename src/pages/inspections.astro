  function initInspectionsPage() {
    // Inject ibox icons (same pattern as industry.astro)
    document.querySelectorAll<HTMLElement>('.ibox[data-icon-slot]').forEach((box) => {
      const slot = box.querySelector('.ibox__icon');
      const i = Number(box.dataset.iconSlot);
      if (slot && IBOX_ICONS[i] && !slot.firstElementChild) {
        slot.innerHTML = IBOX_ICONS[i];
      }
    });
  }

  document.addEventListener('astro:page-load', initInspectionsPage);
  if (document.readyState !== 'loading') initInspectionsPage();
</script>

---
/**
 * Inspections — RRFPS landing page for /inspections.
 *
 * Design DNA pulled from existing pages so the layout feels cohesive:
 *   • industry.astro  — ptbanner (full-bleed hero + 96px title + breadcrumbs),
 *                       2×2 ibox grid (red icon corner + hover-to-orange).
 *   • about.astro     — SplitPanel-style intro band (text + supporting image
 *                       with overlay), DualCTA in the white footer pattern.
 *   • index.astro     — diamond subtitle eyebrow, marquee text style for
 *                       the closing band.
 *
 * Sections, in order (kept small/medium per Zack's direction):
 *   0. Page-title banner (industry.astro §0)
 *   1. Solutions grid — 2×2 ibox of inspection categories (industry.astro §1)
 *   2. Why inspections — bg-image intro panel with photo overlay (about.astro §3
 *      meets industry.astro §2 split-half layout), but lighter than the
 *      priority/accordion block so the page stays small.
 *   3. Inspection process — black-bg SplitPanel with new copy (modeled on
 *      about.astro's "Our Core Values" section). Same image placeholder.
 *   4. Closing marquee + DualCTA.
 *
 * All copy comes from src/data/site.ts → `inspectionsPage`.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import SplitPanel from '../components/SplitPanel.astro';
import DualCTA from '../components/DualCTA.astro';
import { inspectionsPage } from '../data/site';

// Same arrow path & diamond icon used across the demo pages — keep them here
// for visual cohesion (one source per page).
const arrowPath = 'M0 6.78247C0 6.52555 0.102065 6.27914 0.283741 6.09746C0.465416 5.91579 0.711822 5.81372 0.96875 5.81372H12.1927L8.03288 1.65585C7.85097 1.47394 7.74878 1.22723 7.74878 0.969974C7.74878 0.712721 7.85097 0.466004 8.03288 0.284099C8.21478 0.102194 8.4615 0 8.71875 0C8.976 0 9.22272 0.102194 9.40463 0.284099L15.2171 6.0966C15.3073 6.18659 15.3789 6.29349 15.4278 6.41118C15.4766 6.52888 15.5017 6.65505 15.5017 6.78247C15.5017 6.9099 15.4766 7.03607 15.4278 7.15376C15.3789 7.27146 15.3073 7.37836 15.2171 7.46835L9.40463 13.2808C9.22272 13.4628 8.976 13.5649 8.71875 13.5649C8.4615 13.5649 8.21478 13.4628 8.03288 13.2808C7.85097 13.0989 7.74878 12.8522 7.74878 12.595C7.74878 12.3377 7.85097 12.091 8.03288 11.9091L12.1927 7.75122H0.96875C0.711822 7.75122 0.465416 7.64916 0.283741 7.46748C0.102065 7.28581 0 7.0394 0 6.78247Z';

const diamondIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="15" height="20" viewBox="0 0 15 20"><path d="M0.660472 19.6191L0.47542 6.53585L13.7437 19.8041L0.660472 19.6191Z"></path><path d="M14.3396 0.939992L14.5246 14.0232L1.25635 0.754941L14.3396 0.939992Z"></path></svg>';

// Page-title banner image — reuse the same pt-philosophy.webp that industry.astro
// uses (it's wide, on-brand dark, and the only banner candidate in the repo).
const bannerImage = inspectionsPage.banner.backgroundImage;

// Intro panel — dedicated inspection-jobsite photo for the Why Inspections
// band. Replaces the previous jobsite.jpg placeholder with a fully on-topic
// image so the overlay text reads against inspected-system content rather
// than generic trade work.
const introImage = '/images/red-rocks-fire-protection-why-inspections.jpg';
---

<BaseLayout
  title={inspectionsPage.seo.title}
  description={inspectionsPage.seo.description}
>
  <div class="av-page">

    <!-- ══════════════════════════════════════════════════════════
         0. PAGE-TITLE BANNER (industry.astro §0, replicated)
         ══════════════════════════════════════════════════════════ -->
    <div
      class="ptbanner"
      style={`background-image: url('${bannerImage}');`}
    >
      <div class="ptbanner__inner">
        <h1 class="ptbanner__title">{inspectionsPage.banner.title}</h1>
        <div class="ptbanner__breadcrumbs">
          <a href="/">Home</a>
          <span class="ptbanner__divider">-</span>
          <span class="ptbanner__current">{inspectionsPage.banner.subtitle}</span>
        </div>
      </div>
    </div>

    <!-- ══════════════════════════════════════════════════════════
         1. SOLUTIONS GRID — 2×2 of inspection categories
            (industry.astro §1 pattern: sticky headline left + ibox grid right)
         ══════════════════════════════════════════════════════════ -->
    <section class="sol">
      <div class="sol__left">
        <div class="sol__sticky">
          <div class="av-dblh__subtitle">
            <span class="divider-icon" set:html={diamondIcon} />
            <span>What an Inspection Covers</span>
          </div>
          <h2 class="sol__title">
            <span>Every</span>
            <span>System We Touch,</span>
            <span>Inspected Right.</span>
          </h2>
          <div class="sol__spacer" aria-hidden="true"></div>
          <div class="sol__cta">
            <a href="/contact" class="av-wgl-btn av-wgl-btn--outline">
              <span class="av-wgl-btn__text">schedule a walk-through</span>
              <span class="av-wgl-btn__icon">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 14" fill="currentColor" aria-hidden="true"><path d={arrowPath}></path></svg>
              </span>
            </a>
          </div>
        </div>
      </div>

      <div class="sol__grid">
        {inspectionsPage.categories.map((c, i) => (
          <a href="/contact" class="ibox" data-icon-slot={i}>
            <span class="ibox__bg" aria-hidden="true"></span>
            <span class="ibox__icon" aria-hidden="true"></span>
            <span class="ibox__content">
              <h3 class="ibox__title">{c.title}</h3>
              <span class="ibox__text">{c.body}</span>
            </span>
          </a>
        ))}
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════════
         2. WHY INSPECTIONS — bg-image intro with dark overlay
            (about.astro §3 benefits grid BG + a split two-column layout,
             simpler than the priority/accordion block from industry.astro)
         ══════════════════════════════════════════════════════════ -->
    <section class="rr-why">
      <div
        class="rr-why__bg"
        style={`background-image: url('${introImage}');`}
        aria-hidden="true"
      ></div>
      <div class="rr-why__overlay" aria-hidden="true"></div>

      <div class="rr-container">
        <div class="rr-why__grid">
          <div class="rr-why__left">
            <p class="rr-eyebrow rr-eyebrow--light mb-5">{inspectionsPage.intro.eyebrow}</p>
            <h2
              class="font-display font-black uppercase tracking-tight"
              style="font-size: clamp(36px, 5vw, 56px); line-height: 1; letter-spacing: -0.04em;"
            >
              {inspectionsPage.intro.title}
            </h2>
          </div>

          <div class="rr-why__right text-rr-white">
            <p style="font-size: var(--av-text-lead, 18px); line-height: 1.7; color: rgba(255,255,255,0.85); margin-top: 0;">
              {inspectionsPage.intro.body}
            </p>
            <p style="font-size: var(--av-text-lead, 18px); line-height: 1.7; color: rgba(255,255,255,0.85); margin-top: 1.25rem;">
              {inspectionsPage.intro.body2}
            </p>

            <ul class="rr-why__bullets">
              {inspectionsPage.intro.bullets.map((b) => (
                <li class="rr-why__bullet">
                  <span class="rr-why__bullet-mark" aria-hidden="true">▸</span>
                  <span>{b}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════════
         3. INSPECTION PROCESS — black-bg split panel, modeled on
            about.astro's "Our Core Values" section. Same component
            (SplitPanel), same placeholder image, but new INSPECTION-
            SPECIFIC copy from src/data/site.ts → `process`.
         ══════════════════════════════════════════════════════════ -->
    <SplitPanel
      eyebrow={inspectionsPage.process.eyebrow}
      title={inspectionsPage.process.title}
      body={inspectionsPage.process.body}
      ctaLabel={inspectionsPage.process.ctaLabel}
      ctaHref={inspectionsPage.process.ctaHref}
      image={inspectionsPage.process.image}
      imageAlt={inspectionsPage.process.imageAlt}
      background="black"
      ctaVariant="arrow"
      revealTop={false}
    />

    <!-- ══════════════════════════════════════════════════════════
         4. CLOSING — marquee band (index.astro testiominal-marquee style,
            but smaller) + DualCTA in a white band.
         ══════════════════════════════════════════════════════════ -->
    <DualCTA items={inspectionsPage.ctaPair} background="white" />

  </div>
</BaseLayout>

<style>
  /* ══════════════════════════════════════════════════════════
   * Reused from industry.astro (page-title banner + ibox grid)
   * so the visual language matches that page 1:1.
   * ══════════════════════════════════════════════════════════ */

  /* ---- 0. Page-title banner ---- */
  .ptbanner {
    background-size: cover;
    background-repeat: no-repeat;
    background-position: center bottom;
    min-height: 450px;
    margin-bottom: 60px;
    padding-top: 154px;
    padding-bottom: 20px;
    display: flex;
    align-items: flex-end;
  }
  .ptbanner__inner {
    width: 100%;
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: 15px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 20px;
  }
  .ptbanner__title {
    margin: 0;
    color: #ffffff;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: 96px;
    line-height: 104px;
    letter-spacing: -0.05em;
    text-transform: uppercase;
  }
  .ptbanner__breadcrumbs {
    color: #ffffff;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 500;
    font-size: 16px;
    line-height: 30px;
    letter-spacing: -0.04em;
    padding-bottom: 14px;
  }
  .ptbanner__breadcrumbs a {
    color: #ffffff;
    text-decoration: none;
    transition: 0.4s;
  }
  .ptbanner__breadcrumbs a:hover { color: #ffffff99; }
  .ptbanner__divider { margin: 0 10px; }
  .ptbanner__current {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  /* ---- 1. Solutions + ibox grid ---- */
  .sol {
    display: flex;
    max-width: 1600px;
    margin: 0 auto 80px;
  }
  .sol__left { width: 50%; }
  .sol__sticky {
    position: sticky;
    top: 120px;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    padding-right: 0;
  }
  .sol__sticky > * { width: 100%; max-width: 585px; }
  .sol__sticky .av-dblh__subtitle {
    margin-bottom: 23px;
    display: flex;
  }
  .sol__title {
    margin: 0;
    font-family: "Space Grotesk", sans-serif;
    font-size: 56px;
    font-weight: 700;
    text-transform: uppercase;
    line-height: 1.178em;
    padding-bottom: 5px;
    color: #0a0a0a;
  }
  .sol__title span { display: inline-block; }
  .sol__spacer { height: 34px; }
  .sol__cta .av-wgl-btn { display: inline-flex; }
  .sol__cta .av-wgl-btn__text { padding: 17px 35px; }

  .sol__grid {
    width: 50%;
    margin-top: 8px;
    display: flex;
    flex-wrap: wrap;
    row-gap: 30px;
  }
  .sol__grid .ibox { width: 50%; }

  .ibox {
    position: relative;
    display: block;
    text-decoration: none;
    transition: 0.4s;
  }
  .ibox__bg {
    position: absolute;
    inset: 0;
    border: 1px solid #0a0a0a26;
    transition: 0.4s;
    pointer-events: none;
  }
  .ibox:hover { background-color: #fb651b; }
  .ibox:hover .ibox__bg { border-color: transparent; }
  .ibox__icon {
    display: inline-flex;
    background-color: #d41226;
    padding: 16px;
    transition: 0.4s;
  }
  .ibox__icon :global(svg) {
    width: 50px;
    height: 50px;
    fill: #ffffff;
    transition: 0.4s;
  }
  .ibox:hover .ibox__icon { background-color: #ffffff; }
  .ibox:hover .ibox__icon :global(svg) { fill: #0a0a0a; }
  .ibox__content {
    display: flex;
    flex-direction: column;
    min-height: 306px;
    padding: 51px 40px 30px 40px;
  }
  .ibox__title {
    margin: 0;
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(26px, 1.9vw, 30px);
    font-weight: 700;
    text-transform: uppercase;
    line-height: 1.4em;
    color: #0a0a0a;
    transition: 0.4s;
  }
  .ibox__text {
    padding-top: 16px;
    color: #626262;
    font-size: 16px;
    line-height: 1.875;
    transition: 0.4s;
  }
  .ibox:hover .ibox__title,
  .ibox:hover .ibox__text { color: #ffffff; }

  /* ---- 2. Why-inspections band ----
   * about.astro uses a full-bleed photo + dark overlay under its Benefits
   * grid. We adapt that pattern: same bg+overlay, but inside it sit two
   * text columns (eyebrow + headline left, copy + bullets right) instead
   * of a 4-card grid — lighter, more editorial.
   */
  .rr-why {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding-block: 96px;
    color: #ffffff;
    background-color: #0d0d0b;
  }
  @media (min-width: 768px) {
    .rr-why { padding-block: 128px; }
  }
  .rr-why__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    z-index: -2;
  }
  .rr-why__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(0,0,0,0.78) 0%, rgba(0,0,0,0.65) 100%);
    z-index: -1;
  }
  .rr-why__grid {
    display: grid;
    gap: 48px;
    grid-template-columns: 1fr;
    align-items: start;
  }
  @media (min-width: 1024px) {
    .rr-why__grid {
      gap: 80px;
      grid-template-columns: 5fr 7fr;
    }
  }
  .rr-why__left h2 { color: #ffffff; max-width: 16ch; }
  .rr-why__left .rr-eyebrow--light {
    color: rgba(255,255,255,0.7) !important;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .rr-why__bullets {
    list-style: none;
    margin: 1.75rem 0 0;
    padding: 0;
    display: grid;
    gap: 14px;
  }
  .rr-why__bullet {
    display: grid;
    grid-template-columns: 24px 1fr;
    align-items: baseline;
    gap: 4px;
    color: rgba(255,255,255,0.92);
    font-size: 17px;
    line-height: 1.55;
  }
  .rr-why__bullet-mark {
    color: #d41226;
    font-size: 18px;
    line-height: 1;
  }

  /* ---- Responsive ---- */
  @media (max-width: 1200px) {
    .ptbanner__title { font-size: 64px; line-height: 72px; }
    .sol { margin-top: 0; padding: 0 30px; flex-wrap: wrap; }
    .sol__left { width: 100%; }
    .sol__sticky { position: sticky; top: 30px; align-items: flex-start; }
    .sol__sticky > * { max-width: 340px; }
    .sol__title { font-size: 42px; }
    .sol__title span { display: inline; }
    .sol__grid { width: 100%; margin-top: 30px; }
    .sol__grid .ibox { width: 100%; }
    .ibox__content { min-height: 235px; padding: 31px 30px 20px 30px; }
    .ibox__icon :global(svg) { width: 40px; height: 40px; }
    .ibox__title { font-size: 26px; }
    .rr-why { padding-block: 96px; }
  }

  @media (max-width: 767px) {
    .ptbanner { min-height: 320px; padding-top: 120px; }
    .ptbanner__title { font-size: 40px; line-height: 48px; }
    .sol { padding: 0; row-gap: 30px; }
    .sol__sticky { position: relative; top: 0; padding: 0 15px; }
    .sol__title { font-size: 28px; }
    .sol__grid { padding: 0 15px; }
    .ibox__content { min-height: 180px; }
    .rr-why { padding-block: 64px; }
    .rr-why__bullets { gap: 12px; }
    .rr-why__bullet { font-size: 16px; }
  }
</style>

<script>
  /* Inject the four ibox SVG icons from the industry.astro reference. Keeping
   * them inline rather than referencing industry.astro directly because each
   * page is self-contained in this repo (every page carries its own scoped
   * styles and SVG IDs). Reusing the exact same path data guarantees a
   * 1:1 visual match with the other reference pages. */
  const IBOX_ICONS: string[] = [
    /* 0 — clipboard / annual NFPA inspection document */

  function initIndustryPage() {
    // Inject infobox icons
    document.querySelectorAll<HTMLElement>('.ibox[data-icon-slot]').forEach((box) => {
      const slot = box.querySelector('.ibox__icon');
      const i = Number(box.dataset.iconSlot);
      if (slot && IBOX_ICONS[i] && !slot.firstElementChild) slot.innerHTML = IBOX_ICONS[i];
    });

    // Accordion toggle (one open at a time, like the demo)
    const panels = Array.from(document.querySelectorAll<HTMLElement>('[data-acc-panel]'));
    panels.forEach((panel) => {
      const header = panel.querySelector('.acc__header');
      const content = panel.querySelector<HTMLElement>('.acc__content');
      if (!header || !content) return;
      header.addEventListener('click', () => {
        const isOpen = panel.classList.contains('is-active');
        panels.forEach((p) => {
          p.classList.remove('is-active');
          p.querySelector('.acc__header')?.setAttribute('aria-expanded', 'false');
          const c = p.querySelector<HTMLElement>('.acc__content');
          if (c) c.hidden = true;
        });
        if (!isOpen) {
          panel.classList.add('is-active');
          header.setAttribute('aria-expanded', 'true');
          content.hidden = false;
        }
      });
    });
  }

  document.addEventListener('astro:page-load', initIndustryPage);
  if (document.readyState !== 'loading') initIndustryPage();
</script>

<!-- Swiper 11 (CDN) for the testimonials carousel -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<script is:inline src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
  declare const Swiper: any;

  function initIndustrySwipers() {
    if (typeof Swiper === 'undefined') return;
    const tmEl = document.querySelector('.tm__swiper') as any;
    if (tmEl && !tmEl.swiper) {
      new Swiper(tmEl, {
        slidesPerView: 1,
        spaceBetween: 30,
        loop: true,
        speed: 800,
        navigation: {
          prevEl: '.tm__nav-prev',
          nextEl: '.tm__nav-next',
        },
      });
    }
  }

  document.addEventListener('astro:page-load', initIndustrySwipers);
  let swTries = 0;
  const swTick = () => {
    if (typeof Swiper !== 'undefined') initIndustrySwipers();
    else if (swTries++ < 50) setTimeout(swTick, 100);
  };
  swTick();
</script>

---
/**
 * Industry — 1:1 replica of the Avelon demo "Philosophy" page
 * (https://woocommerce-718927-6369698.cloudwaysapps.com/philosophy/)
 *
 * Structure + every pixel value extracted from the demo's Elementor CSS
 * (post-1235.css) and the page-header inline styles:
 *
 *   0. Page-title banner — pt-philosophy.webp, min-height 450, 96px title,
 *      breadcrumbs inline right
 *   1. Solutions — sticky left heading (585px, top 120) + ALL SERVICES,
 *      right 2×2 infobox grid (border #0A0A0A26, hover #FB651B)
 *   2. Priority — philosophy-bg.webp section (padding 142/152), right column
 *      "Your Project, Our Priority" + 3-panel accordion (665px)
 *   3. Slider — 3 full-height photo columns (revslider-1/2/3), 800px tall,
 *      1200px grid: number 32px · title 40px · READ MORE, anchored bottom
 *   4. Testimonials — 170px white-stroke marquee (margin 97/-76) ·
 *      hist-testi.webp (530px) + 36px quote carousel (PREV/NEXT) ·
 *      4 avatar logos + "200+ happy customers"
 */

import BaseLayout from '../layouts/BaseLayout.astro';

const arrowPath = 'M0 6.78247C0 6.52555 0.102065 6.27914 0.283741 6.09746C0.465416 5.91579 0.711822 5.81372 0.96875 5.81372H12.1927L8.03288 1.65585C7.85097 1.47394 7.74878 1.22723 7.74878 0.969974C7.74878 0.712721 7.85097 0.466004 8.03288 0.284099C8.21478 0.102194 8.4615 0 8.71875 0C8.976 0 9.22272 0.102194 9.40463 0.284099L15.2171 6.0966C15.3073 6.18659 15.3789 6.29349 15.4278 6.41118C15.4766 6.52888 15.5017 6.65505 15.5017 6.78247C15.5017 6.9099 15.4766 7.03607 15.4278 7.15376C15.3789 7.27146 15.3073 7.37836 15.2171 7.46835L9.40463 13.2808C9.22272 13.4628 8.976 13.5649 8.71875 13.5649C8.4615 13.5649 8.21478 13.4628 8.03288 13.2808C7.85097 13.0989 7.74878 12.8522 7.74878 12.595C7.74878 12.3377 7.85097 12.091 8.03288 11.9091L12.1927 7.75122H0.96875C0.711822 7.75122 0.465416 7.64916 0.283741 7.46748C0.102065 7.28581 0 7.0394 0 6.78247Z';

const diamondIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="15" height="20" viewBox="0 0 15 20"><path d="M0.660472 19.6191L0.47542 6.53585L13.7437 19.8041L0.660472 19.6191Z"></path><path d="M14.3396 0.939992L14.5246 14.0232L1.25635 0.754941L14.3396 0.939992Z"></path></svg>';

const solutions = [
  {
    title: 'General Contracting',
    body: 'Comprehensive management and execution of construction projects from start to finish.',
  },
  {
    title: 'Design & Build',
    body: 'An integrated approach that combines architectural design, engineering, and construction under one roof.',
  },
  {
    title: 'Project Management',
    body: 'Professional planning, scheduling, budgeting, and oversight to keep every project on track.',
  },
  {
    title: 'building construction',
    body: 'From modern homes to apartment complexes, we bring residential visions to life with precision.',
  },
];

const accordionBody = 'Our advanced seeds, soil care, and farming techniques help farmers produce more — with less. We promote eco-friendly practices that protect soil, water, and biodiversity for long-term success.';
const accordionPanels = [
  { title: 'Reliability and Transparency', open: true },
  { title: 'Innovation and Technology', open: false },
  { title: 'Expert Project Management', open: false },
];

const sliderPanels = [
  { number: '01', title: 'Residential Constructing', image: '/images/industry/revslider-1_1.jpeg' },
  { number: '02', title: 'Project Management', image: '/images/industry/revslider-2_2.jpeg' },
  { number: '03', title: 'Structural Work', image: '/images/industry/revslider-3_3.jpeg' },
];

const testimonialQuote = '“From branding to website development, this team exceeded our expectations. Their creativity and technical expertise brought our vision to life seamlessly.”';
const testimonials = [
  { name: 'Christian Grant', position: 'Company client' },
  { name: 'Matey Grant', position: 'Company client' },
  { name: 'Marry Parton', position: 'Company client' },
  { name: 'Luis Vireon', position: 'Company client' },
];
---

<BaseLayout
  title="Philosophy | Red Rocks Fire Protection"
  description="Comprehensive solutions for every project — Red Rocks Fire Protection philosophy."
>
  <div class="av-page">

    <!-- ════════════════════════════════════════════════════════
         0. PAGE-TITLE BANNER
         ════════════════════════════════════════════════════════ -->
    <div class="ptbanner">
      <div class="ptbanner__inner">
        <h1 class="ptbanner__title">PHILOSOPHY</h1>
        <div class="ptbanner__breadcrumbs">
          <a href="/">Home</a>
          <span class="ptbanner__divider">-</span>
          <span class="ptbanner__current">PHILOSOPHY</span>
        </div>
      </div>
    </div>

    <!-- ════════════════════════════════════════════════════════
         1. SOLUTIONS — sticky heading + 2×2 infobox grid
         ════════════════════════════════════════════════════════ -->
    <section class="sol">
      <div class="sol__left">
        <div class="sol__sticky">
          <div class="av-dblh__subtitle">
            <span class="divider-icon" set:html={diamondIcon} />
            <span>From Design to Delivery</span>
          </div>
          <h2 class="sol__title">
            <span>Comprehensive</span>
            <span>Solutions&nbsp; for Every</span>
            <span>Project</span>
          </h2>
          <div class="sol__spacer" aria-hidden="true"></div>
          <div class="sol__cta">
            <a href="/services" class="av-wgl-btn av-wgl-btn--outline">
              <span class="av-wgl-btn__text">all services</span>
              <span class="av-wgl-btn__icon">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 14" fill="currentColor" aria-hidden="true"><path d={arrowPath}></path></svg>
              </span>
            </a>
          </div>
        </div>
      </div>

      <div class="sol__grid">
        {solutions.map((s, i) => (
          <a href="/about" class="ibox" data-icon-slot={i}>
            <span class="ibox__bg" aria-hidden="true"></span>
            <span class="ibox__icon" aria-hidden="true"></span>
            <span class="ibox__content">
              <h3 class="ibox__title">{s.title}</h3>
              <span class="ibox__text">{s.body}</span>
            </span>
          </a>
        ))}
      </div>
    </section>

    <!-- ════════════════════════════════════════════════════════
         2. PRIORITY — philosophy-bg + accordion
         ════════════════════════════════════════════════════════ -->
    <section class="prio">
      <div class="prio__left" aria-hidden="true"></div>
      <div class="prio__right">
        <div class="av-dblh__subtitle">
          <span class="divider-icon" set:html={diamondIcon} />
          <span>Partnering for Success</span>
        </div>
        <h3 class="prio__title">
          <span>Your Project,</span>
          <span>Our Priority</span>
        </h3>

        <div class="acc">
          {accordionPanels.map((p) => (
            <div class:list={['acc__panel', p.open && 'is-active']} data-acc-panel>
              <button type="button" class="acc__header" aria-expanded={p.open ? 'true' : 'false'}>
                <span class="acc__icon" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 14" fill="currentColor"><path d={arrowPath}></path></svg>
                </span>
                <span class="acc__title">{p.title}</span>
              </button>
              <div class="acc__content" hidden={!p.open}>
                <p>{accordionBody}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════════════════════════
         3. SLIDER — 3 photo columns
         ════════════════════════════════════════════════════════ -->
    <section class="slider">
      {sliderPanels.map((p) => (
        <a href="/services" class="slider__col" style={`background-image: url('${p.image}')`}>
          <span class="slider__overlay" aria-hidden="true"></span>
          <span class="slider__content">
            <span class="slider__number">{p.number}</span>
            <span class="slider__title">{p.title}</span>
            <span class="slider__more">READ MORE</span>
          </span>
        </a>
      ))}
    </section>

    <!-- ════════════════════════════════════════════════════════
         4. TESTIMONIALS
         ════════════════════════════════════════════════════════ -->
    <section class="tm">
      <div class="av-loop tm__marquee" aria-hidden="true">
        {[0, 1, 2].map(() => (
          <div class="av-loop__track">
            <h3 class="tm__marquee-text">
              WHAT CLIENTS SAY ABOUT US&nbsp; WHAT CLIENTS SAY ABOUT US&nbsp; WHAT CLIENTS SAY ABOUT US&nbsp; WHAT CLIENTS SAY ABOUT US&nbsp;
            </h3>
          </div>
        ))}
      </div>

      <div class="tm__row">
        <div class="tm__image">
          <img src="/images/industry/hist-testi.webp" alt="Construction detail" loading="lazy" />
        </div>

        <div class="tm__col">
          <div class="tm__carousel">
            <div class="swiper tm__swiper">
              <div class="swiper-wrapper">
                {testimonials.map((t) => (
                  <div class="swiper-slide">
                    <div class="tm-item">
                      <div class="tm-item__quote">{testimonialQuote}</div>
                      <div class="tm-item__author">
                        <h3 class="tm-item__name">{t.name}</h3>
                        <span class="tm-item__position">{t.position}</span>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
            <div class="tm__nav">
              <button type="button" class="tm__nav-btn tm__nav-prev">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 14" fill="currentColor" style="transform: scaleX(-1)" aria-hidden="true"><path d={arrowPath}></path></svg>
                <span>PREV</span>
              </button>
              <button type="button" class="tm__nav-btn tm__nav-next">
                <span>NEXT</span>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 14" fill="currentColor" aria-hidden="true"><path d={arrowPath}></path></svg>
              </button>
            </div>
          </div>

          <div class="tm__spacer" aria-hidden="true"></div>

          <div class="tm__customers">
            {[1, 2, 3, 4].map((n) => (
              <img
                src={`/images/industry/testimonials-logo-${n}.webp`}
                alt=""
                class="tm__avatar"
                loading="lazy"
              />
            ))}
            <h2 class="tm__customers-label">200+&nbsp;happy customers</h2>
          </div>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  /* ══════════════════════════════════════════════════════════
   * 0. PAGE-TITLE BANNER (page-header inline styles from the demo)
   * ══════════════════════════════════════════════════════════ */
  .ptbanner {
    background-image: url('/images/industry/pt-philosophy.webp');
    background-size: cover;
    background-repeat: no-repeat;
    background-position: center bottom;
    min-height: 450px;
    margin-bottom: 60px;
    padding-top: 154px;
    padding-bottom: 20px;
    display: flex;
    align-items: flex-end;
  }
  .ptbanner__inner {
    width: 100%;
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: 15px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 20px;
  }
  .ptbanner__title {
    margin: 0;
    color: #ffffff;
    font-weight: 700;
    font-size: 96px;
    line-height: 104px;
    letter-spacing: -0.05em;
    text-transform: uppercase;
  }
  .ptbanner__breadcrumbs {
    color: #ffffff;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 500;
    font-size: 16px;
    line-height: 30px;
    letter-spacing: -0.04em;
    padding-bottom: 14px;
  }
  .ptbanner__breadcrumbs a {
    color: #ffffff;
    text-decoration: none;
    transition: 0.4s;
  }
  .ptbanner__breadcrumbs a:hover { color: #ffffff99; }
  .ptbanner__divider { margin: 0 10px; }
  .ptbanner__current {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  /* ══════════════════════════════════════════════════════════
   * 1. SOLUTIONS (sticky left + 2×2 grid right)
   * ══════════════════════════════════════════════════════════ */
  .sol {
    display: flex;
    max-width: 1600px;
    /* demo: banner margin-bottom 60px + section margin-top 51px (no collapse) */
    margin: 111px auto 0;
  }
  .sol__left { width: 50%; }
  .sol__sticky {
    position: sticky;
    top: 120px;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    padding-right: 0;
  }
  .sol__sticky > * { width: 100%; max-width: 585px; }
  .sol__sticky .av-dblh__subtitle {
    margin-bottom: 23px;
    display: flex;
  }
  .sol__title {
    margin: 0;
    font-size: 56px;
    text-transform: uppercase;
    line-height: 1.178em;
    padding-bottom: 5px;
  }
  .sol__title span { display: inline-block; }
  .sol__spacer { height: 34px; }
  .sol__cta .av-wgl-btn { display: inline-flex; }
  .sol__cta .av-wgl-btn__text { padding: 17px 35px; }

  .sol__grid {
    width: 50%;
    margin-top: 8px;
    display: flex;
    flex-wrap: wrap;
    row-gap: 30px;
  }
  .sol__grid .ibox { width: 50%; }

  .ibox {
    position: relative;
    display: block;
    text-decoration: none;
    transition: 0.4s;
  }
  .ibox__bg {
    position: absolute;
    inset: 0;
    border: 1px solid #0a0a0a26;
    transition: 0.4s;
    pointer-events: none;
  }
  .ibox:hover { background-color: #fb651b; }
  .ibox:hover .ibox__bg { border-color: transparent; }
  .ibox__icon {
    display: inline-flex;
    background-color: #d41226;
    padding: 16px;
    transition: 0.4s;
  }
  .ibox__icon :global(svg) {
    width: 50px;
    height: 50px;
    fill: #ffffff;
    transition: 0.4s;
  }
  .ibox:hover .ibox__icon { background-color: #ffffff; }
  .ibox:hover .ibox__icon :global(svg) { fill: #0a0a0a; }
  .ibox__content {
    display: flex;
    flex-direction: column;
    min-height: 306px;
    padding: 51px 40px 30px 40px;
  }
  .ibox__title {
    margin: 0;
    font-size: clamp(26px, 1.9vw, 30px);
    text-transform: uppercase;
    line-height: 1.4em;
    color: #0a0a0a;
    transition: 0.4s;
  }
  .ibox__text {
    padding-top: 16px;
    color: #626262;
    font-size: 16px;
    line-height: 1.875;
    transition: 0.4s;
  }
  .ibox:hover .ibox__title,
  .ibox:hover .ibox__text { color: #ffffff; }

  /* ══════════════════════════════════════════════════════════
   * 2. PRIORITY (philosophy-bg + accordion)
   * ══════════════════════════════════════════════════════════ */
  .prio {
    display: flex;
    margin-top: 150px;
    padding: 142px 0 152px;
    background-image: url('/images/industry/philosophy-bg.webp');
    background-position: center center;
    background-repeat: no-repeat;
    background-size: cover;
  }
  .prio__left { width: 50%; }
  .prio__right { width: 50%; }
  .prio__right .av-dblh__subtitle { margin-bottom: 23px; }
  .prio__title {
    margin: 0;
    font-size: 56px;
    text-transform: uppercase;
    line-height: 1.178em;
  }
  .prio__title span { display: inline-block; }

  .acc {
    max-width: 665px;
    margin-top: 40px;
  }
  .acc__panel {
    overflow: hidden;
    padding: 15px 0;
    border-top: 1px solid rgba(10, 10, 10, 0.2);
    transition: border-color 0.4s;
  }
  .acc__panel:first-child { border-top: none; }
  .acc__panel:last-child { border-bottom: 1px solid rgba(10, 10, 10, 0.2); }
  .acc__panel:hover,
  .acc__panel.is-active,
  .acc__panel:hover + .acc__panel,
  .acc__panel.is-active + .acc__panel { border-top-color: #d41226; }
  .acc__panel.is-active:last-child,
  .acc__panel:hover:last-child { border-bottom-color: #d41226; }

  .acc__header {
    display: flex;
    align-items: flex-start;
    width: 100%;
    background: none;
    border: none;
    padding: 13px 0;
    cursor: pointer;
    text-align: left;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: 24px;
    letter-spacing: -0.02em;
    color: #0a0a0a;
  }
  .acc__icon {
    display: inline-flex;
    align-self: flex-start;
    margin: 8px 18px -15px 2px;
    color: #d41226;
    transform: rotate(90deg);
    transition: transform 0.4s;
  }
  .acc__panel.is-active .acc__icon { transform: rotate(-90deg); }
  .acc__icon svg { width: 18px; height: 16px; }
  .acc__content {
    padding: 6px 5px 14px 39px;
    color: #626262;
    font-size: 16px;
    line-height: 1.875;
  }
  .acc__content p { margin: 0; }

  /* ══════════════════════════════════════════════════════════
   * 3. SLIDER (3 photo columns, 800px)
   * ══════════════════════════════════════════════════════════ */
  .slider {
    display: flex;
    height: 800px;
  }
  .slider__col {
    position: relative;
    width: 33.3333%;
    background-size: cover;
    background-position: center;
    text-decoration: none;
    overflow: hidden;
    transition: 0.4s;
  }
  .slider__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.55) 0%, rgba(0, 0, 0, 0.1) 50%, rgba(0, 0, 0, 0) 100%);
    transition: 0.4s;
  }
  .slider__col:hover .slider__overlay { background: linear-gradient(to top, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0.25) 60%, rgba(0, 0, 0, 0.1) 100%); }
  .slider__content {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    bottom: 40px;
    width: 370px;
    max-width: 85%;
    display: flex;
    flex-direction: column;
    color: #ffffff;
  }
  .slider__number {
    font-family: "Inter", sans-serif;
    font-size: 32px;
    font-weight: 500;
    line-height: 38px;
  }
  .slider__title {
    margin-top: 17px;
    font-family: "Inter", sans-serif;
    font-size: 40px;
    font-weight: 700;
    line-height: 50px;
    text-transform: uppercase;
  }
  .slider__more {
    margin-top: 20px;
    margin-left: 26px;
    font-family: "Inter", sans-serif;
    font-size: 16px;
    font-weight: 700;
    line-height: 30px;
    border-bottom: 2px solid #ffffff;
    align-self: flex-start;
    transition: 0.4s;
  }
  .slider__col:hover .slider__more { color: #d41226; border-color: #d41226; }

  /* ══════════════════════════════════════════════════════════
   * 4. TESTIMONIALS (identical block to the demo home page)
   * ══════════════════════════════════════════════════════════ */
  .tm { background: #ffffff; overflow: hidden; }
  .tm__marquee {
    --av-loop-gap: 60px;
    --av-loop-duration: 300s;
    margin-top: 97px;
    margin-bottom: -76px;
  }
  .tm__marquee-text {
    margin: 0;
    font-size: 170px;
    font-weight: 700;
    line-height: 1.2;
    color: #ffffff;
    -webkit-text-stroke-width: 1px;
    -webkit-text-stroke-color: #00000033;
  }
  .tm__row {
    display: flex;
    align-items: center;
    margin-bottom: 109px;
  }
  .tm__image { width: 50%; }
  .tm__image img {
    width: 530px;
    max-width: 100%;
    height: auto;
    display: block;
  }
  .tm__col { width: 50%; }
  .tm__carousel {
    padding: 28px 0 38px;
    border-bottom: 1px solid #0a0a0a33;
  }
  .tm-item__quote {
    font-family: "Space Grotesk", sans-serif;
    font-size: 36px;
    font-weight: 500;
    line-height: 1.39em;
    letter-spacing: -0.05em;
    padding-right: 18px;
    color: #0a0a0a;
    margin-bottom: 40px;
  }
  .tm-item__name {
    margin: 0;
    font-size: 24px;
    line-height: 1.3;
  }
  .tm-item__position {
    font-size: 14px;
    color: #626262;
  }
  .tm__nav {
    display: flex;
    justify-content: flex-end;
    gap: 24px;
    margin: 0 0 2px 0;
  }
  .tm__nav-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: 14px;
    color: #0a0a0a;
    transition: 0.4s;
  }
  .tm__nav-btn:hover { color: #d41226; }
  .tm__nav-btn svg { width: 16px; height: 14px; }
  .tm__spacer { height: 48px; }

  .tm__customers {
    display: flex;
    align-items: center;
    margin-left: -3px;
  }
  .tm__avatar {
    width: 60px;
    height: 60px;
    border: 3px solid #ffffff;
    border-radius: 60px;
    object-fit: cover;
  }
  .tm__avatar + .tm__avatar { margin-left: -9px; }
  .tm__customers-label {
    max-width: 100px;
    margin: 0 0 0 19px;
    font-size: 14px;
    text-transform: uppercase;
    line-height: 18px;
    color: #ffffff;
  }

  /* ══════════════════════════════════════════════════════════
   * Responsive — breakpoints from post-1235.css
   * ══════════════════════════════════════════════════════════ */
  @media (max-width: 1200px) {
    .ptbanner__title { font-size: 64px; line-height: 72px; }

    .sol { margin-top: 0; padding: 0 30px; flex-wrap: wrap; }
    .sol__left { width: 100%; }
    .sol__sticky { position: sticky; top: 30px; align-items: flex-start; }
    .sol__sticky > * { max-width: 340px; }
    .sol__title { font-size: 42px; }
    .sol__title span { display: inline; }
    .sol__grid { width: 100%; margin-top: 30px; }
    .sol__grid .ibox { width: 100%; }
    .ibox__content { min-height: 235px; padding: 31px 30px 20px 30px; }
    .ibox__icon :global(svg) { width: 40px; height: 40px; }
    .ibox__title { font-size: 26px; }


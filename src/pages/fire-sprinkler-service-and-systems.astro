  function initFireSprinklerPage() {
    // Inject ibox icons into §1's 4 boxes (same pattern as inspections.astro)
    document.querySelectorAll<HTMLElement>('.ibox[data-icon-slot]').forEach((box) => {
      const slot = box.querySelector<HTMLElement>('.ibox__icon');
      const i = Number(box.dataset.iconSlot);
      if (slot && IBOX_ICONS[i] && !slot.firstElementChild) {
        slot.innerHTML = IBOX_ICONS[i];
      }
    });
  }

  /**
   * Accordion toggle for the §3 "Our Fire Sprinkler Services" section.
   * Mirrors the multi-family-management-companies.astro behaviour: one
   * panel open at a time; clicking the open panel closes it.
   *
   * Defensive against Astro View Transitions + early-load timing:
   *  - Registers on astro:page-load (after Astro swaps DOM in)
   *  - Registers on astro:after-swap (extra safety net)
   *  - Registers on DOMContentLoaded (covers the direct-nav case)
   *  - Calls once immediately if document is already interactive
   *  - Schedules a 100 ms microtask re-run as a catch-all so panel
   *    listeners get attached even if the very first paint tick
   *    happened before the panel markup was slotted in
   */
  function initFireSprinklerAccordion() {
    const panels = Array.from(document.querySelectorAll<HTMLElement>('[data-acc-panel]'));
    if (!panels.length) return false;
    panels.forEach((panel) => {
      const header = panel.querySelector<HTMLElement>('.acc__header');
      const content = panel.querySelector<HTMLElement>('.acc__content');
      if (!header || !content) return;
      // Skip if listener already attached (idempotent across page-loads).
      if ((header as any).__fsAccordionWired) return;
      (header as any).__fsAccordionWired = true;
      header.addEventListener('click', () => {
        const wasOpen = panel.classList.contains('is-active');
        panels.forEach((p) => {
          p.classList.remove('is-active');
          p.querySelector<HTMLElement>('.acc__header')?.setAttribute('aria-expanded', 'false');
          const c = p.querySelector<HTMLElement>('.acc__content');
          if (c) c.hidden = true;
        });
        if (!wasOpen) {
          panel.classList.add('is-active');
          header.setAttribute('aria-expanded', 'true');
          content.hidden = false;
        }
      });
    });
    return true;
  }

  function bindFireSprinklerPage() {
    initFireSprinklerPage();
    if (!initFireSprinklerAccordion()) {
      // Panels not in DOM yet — try again on the next microtask.
      setTimeout(initFireSprinklerAccordion, 100);
    }
  }

  document.addEventListener('astro:page-load', bindFireSprinklerPage);
  document.addEventListener('astro:after-swap', bindFireSprinklerPage);
  document.addEventListener('DOMContentLoaded', bindFireSprinklerPage);
  if (document.readyState !== 'loading') bindFireSprinklerPage();
</script>

---
/**
 * Fire Sprinkler Service & Systems — RRFPS landing page for
 * /fire-sprinkler-service-and-systems/.
 *
 * Design DNA pulled from existing pages so the layout feels cohesive:
 *   • inspections.astro                  — ptbanner, 2×2 ibox grid, `rr-why`
 *                                          bg-image intro band, closing
 *                                          DualCTA. Used in order as the
 *                                          first sections on this page.
 *   • multi-family-management-companies  — accordion (5 panels) for the
 *                                          service scope; SplitPanel bridge
 *                                          reuse pattern (white-bg + black-bg
 *                                          variants); 2×2 testimonials grid.
 *                                          (The 3-photo slider section is
 *                                          deliberately NOT used here.)
 *   • about.astro                        — bg-image 4-card grid adapted for
 *                                          the 14-industries list; the Our
 *                                          Core Values SplitPanel as a
 *                                          reusable SplitPanel template.
 *
 * Sections, in order:
 *   0. ptbanner                          — inspections.astro §0 (white text
 *                                          on dark image bg)
 *   1. 2×2 ibox grid                     — inspections.astro §1 (sticky
 *                                          headline left + 4 iboxes right;
 *                                          cards summarize 4 service lines)
 *   2. `rr-why` bg-image intro band      — inspections.astro §2 (dark bg +
 *                                          overlay + two text columns)
 *   3. 5-panel accordion                 — multi-family.astro §2 (dark bg +
 *                                          overlay, accordion rows)
 *   4. SplitPanel — More Than a…         — white-bg variant of the about.astro
 *                                          §2 / Our Core Values pattern (image
 *                                          on the right)
 *   5. SplitPanel — Advocacy             — multi-family.astro §4 pattern
 *                                          (black-bg, no reveal-top)
 *   6. SplitPanel — Why Clients Stay     — black-bg variant of the about.astro
 *                                          §2 / Our Core Values pattern (image
 *                                          on the left), with a 5-card
 *                                          values grid replacing the body slot
 *   7. SplitPanel — Experience           — multi-family.astro §1 pattern
 *                                          (white-bg, image on the right)
 *   8. 14-industries bg-image grid       — about.astro §3 (Benefits pattern,
 *                                          dark bg + overlay, transparent
 *                                          white-tinted 4-card grid — titles-
 *                                          only)
 *   9. SplitPanel — Protecting…          — black-bg variant of the
 *                                          multi-family.astro §1 pattern
 *                                          (image on the right)
 *  10. Closing band + DualCTA            — inspections.astro §4 pattern, but
 *                                          with the .txt closing copy + phone
 *                                          number rendered above the DualCTA
 *
 * Theme rhythm (no two same-theme back-to-back):
 *   §0 dark  → §1 white  → §2 dark-image  → §3 dark-accordion  →
 *   §4 white  → §5 black  → §6 black  ← §5 stays white below →
 *   §7 white  → §8 dark-image  → §9 black  → §10 white ✅
 *
 * All copy comes verbatim from
 * reference/content/rrfps-fire-sprinkler-services-and-systems-page-content.txt,
 * surfaced through src/data/site.ts → `fireSprinklerPage`. The phone number
 * `(303) 663-0397` used in the closing band is the number supplied by the
 * .txt source file (intentionally not the canonical site.ts contact.phone
 * — the canonical number is still used for the `/contact` link target).
 *
 * Image placeholders:
 *   • rr-why / accordion background images:
 *       /images/rrfps-fire-sprinkler-systems-hero.jpg (per page spec)
 *   • All SplitPanel foreground images:
 *       /images/our-core-values.jpg (per page spec)
 * Swap these via site.ts once the real per-section assets are supplied.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import SplitPanel from '../components/SplitPanel.astro';
import DualCTA from '../components/DualCTA.astro';
import { fireSprinklerPage } from '../data/site';

const arrowPath = 'M0 6.78247C0 6.52555 0.102065 6.27914 0.283741 6.09746C0.465416 5.91579 0.711822 5.81372 0.96875 5.81372H12.1927L8.03288 1.65585C7.85097 1.47394 7.74878 1.22723 7.74878 0.969974C7.74878 0.712721 7.85097 0.466004 8.03288 0.284099C8.21478 0.102194 8.4615 0 8.71875 0C8.976 0 9.22272 0.102194 9.40463 0.284099L15.2171 6.0966C15.3073 6.18659 15.3789 6.29349 15.4278 6.41118C15.4766 6.52888 15.5017 6.65505 15.5017 6.78247C15.5017 6.9099 15.4766 7.03607 15.4278 7.15376C15.3789 7.27146 15.3073 7.37836 15.2171 7.46835L9.40463 13.2808C9.22272 13.4628 8.976 13.5649 8.71875 13.5649C8.4615 13.5649 8.21478 13.4628 8.03288 13.2808C7.85097 13.0989 7.74878 12.8522 7.74878 12.595C7.74878 12.3377 7.85097 12.091 8.03288 11.9091L12.1927 7.75122H0.96875C0.711822 7.75122 0.465416 7.64916 0.283741 7.46748C0.102065 7.28581 0 7.0394 0 6.78247Z';

const diamondIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="15" height="20" viewBox="0 0 15 20"><path d="M0.660472 19.6191L0.47542 6.53585L13.7437 19.8041L0.660472 19.6191Z"></path><path d="M14.3396 0.939992L14.5246 14.0232L1.25635 0.754941L14.3396 0.939992Z"></path></svg>';

const bannerImage = fireSprinklerPage.banner.backgroundImage;
---

<BaseLayout
  title={fireSprinklerPage.seo.title}
  description={fireSprinklerPage.seo.description}
>
  <div class="av-page">

    <!-- ══════════════════════════════════════════════════════════
         §0. PAGE-TITLE BANNER (inspections.astro §0)
            (RRFPS-2 hero revision: bg image is
             rrfps-our-fire-sprinkler-services.jpg; a light overlay
             sits between the bg image and the text so the white
             headline + breadcrumb read clearly against the photo.)
         ══════════════════════════════════════════════════════════ -->
    <div class="ptbanner">
      <div class="ptbanner__bg" style={`background-image: url('${bannerImage}');`} aria-hidden="true"></div>
      <div class="ptbanner__overlay" aria-hidden="true"></div>
      <div class="ptbanner__inner">
        <h1 class="ptbanner__title">{fireSprinklerPage.banner.title}</h1>
        <div class="ptbanner__breadcrumbs">
          <a href="/">Home</a>
          <span class="ptbanner__divider">-</span>
          <span class="ptbanner__current">{fireSprinklerPage.banner.subtitle}</span>
        </div>
      </div>
    </div>

    <!-- ══════════════════════════════════════════════════════════
         §1. SOLUTIONS GRID — 2×2 ibox (inspections.astro §1, white)
         ══════════════════════════════════════════════════════════ -->
    <section class="sol">
      <div class="sol__left">
        <div class="sol__sticky">
          <div class="av-dblh__subtitle">
            <span class="divider-icon" set:html={diamondIcon} />
            <span>What Fire Sprinkler Service Covers</span>
          </div>
          <h2 class="sol__title">
            <span>Service,</span>
            <span>Modifications,</span>
            <span>Replacement,</span>
            <span>and 24/7 Response.</span>
          </h2>
          <div class="sol__spacer" aria-hidden="true"></div>
          <div class="sol__cta">
            <a href="/contact" class="av-wgl-btn av-wgl-btn--outline">
              <span class="av-wgl-btn__text">request a walk-through</span>
              <span class="av-wgl-btn__icon">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 14" fill="currentColor" aria-hidden="true"><path d={arrowPath}></path></svg>
              </span>
            </a>
          </div>
        </div>
      </div>

      <div class="sol__grid">
        {fireSprinklerPage.categories.map((c, i) => (
          <a href="/contact" class="ibox" data-icon-slot={i}>
            <span class="ibox__bg" aria-hidden="true"></span>
            <span class="ibox__icon" aria-hidden="true"></span>
            <span class="ibox__content">
              <h3 class="ibox__title">{c.title}</h3>
              <span class="ibox__text">{c.body}</span>
            </span>
          </a>
        ))}
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════════
         §2. WHY RED ROCKS — solid black background, reveal-top
            (revision RRFPS-2: removed bg image, switched from
            inspections.astro's `rr-why` pattern to a clean
            black-band pattern)
         ══════════════════════════════════════════════════════════ -->
    <section class="rr-band rr-band--reveal-top bg-rr-black text-rr-white">
      <div class="rr-container">
        <div class="fs-why-grid">
          <div class="fs-why-grid__left">
            <p class="rr-eyebrow mb-5" style="color: rgba(255,255,255,0.7);">{fireSprinklerPage.intro.eyebrow}</p>
            <h2
              class="font-display font-black uppercase tracking-tight"
              style="font-size: clamp(36px, 5vw, 56px); line-height: 1; letter-spacing: -0.04em; color: #fff;"
            >
              {fireSprinklerPage.intro.title}
            </h2>
          </div>

          <div class="fs-why-grid__right">
            <p class="fs-why-grid__body" style="font-size: var(--av-text-lead, 18px); line-height: 1.7; color: rgba(255,255,255,0.85); margin-top: 0;">
              {fireSprinklerPage.intro.body}
            </p>
            <p class="fs-why-grid__body" style="font-size: var(--av-text-lead, 18px); line-height: 1.7; color: rgba(255,255,255,0.85); margin-top: 1.25rem;">
              {fireSprinklerPage.intro.body2}
            </p>

            <ul class="rr-why__bullets">
              {fireSprinklerPage.intro.bullets.map((b) => (
                <li class="rr-why__bullet">
                  <span class="rr-why__bullet-mark" aria-hidden="true">▸</span>
                  <span>{b}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════════
         §3. ACCORDION — 5 panels of service scope
            (multi-family.astro §2 challenges, dark image-bg)
         ══════════════════════════════════════════════════════════ -->
    <section class="fs-accordion">
      <div class="fs-accordion__bg" aria-hidden="true"></div>

      <div class="fs-accordion__inner">
        <div class="av-dblh__subtitle">
          <span class="divider-icon" set:html={diamondIcon} />
          <span>{fireSprinklerPage.accordion.eyebrow}</span>
        </div>
        <h3 class="fs-accordion__title">{fireSprinklerPage.accordion.title}</h3>

        <div class="fs-accordion__layout">
          <div class="fs-accordion__left">
            <p class="fs-accordion__intro">{fireSprinklerPage.accordion.intro}</p>
          </div>

          <div class="acc fs-accordion__right">
            {fireSprinklerPage.accordion.panels.map((p) => (
              <div class:list={['acc__panel', p.open && 'is-active']} data-acc-panel>
                <button type="button" class="acc__header" aria-expanded={p.open ? 'true' : 'false'}>
                  <span class="acc__icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 14" fill="currentColor"><path d={arrowPath}></path></svg>
                  </span>
                  <span class="acc__title">{p.title}</span>
                </button>
                <div class="acc__content" hidden={!p.open}>
                  <p>{p.body}</p>
                  {p.bullets && p.bullets.length > 0 && (
                    <ul class="acc__bullets">
                      {p.bullets.map((b) => (
                        <li class="acc__bullet">
                          <span class="acc__bullet-mark" aria-hidden="true">▸</span>
                          <span>{b}</span>
                        </li>
                      ))}
                    </ul>
                  )}
                  {p.footer && (
                    <p class="acc__footer">{p.footer}</p>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════════
         §4. SPLITPANEL — More Than a Fire Sprinkler Contractor
            (white-bg variant of about.astro §2 / Our Core Values
             pattern — splits rhythm from the dark accordion §3)
         ══════════════════════════════════════════════════════════ -->
    <SplitPanel
      eyebrow={fireSprinklerPage.moreThanContractor.eyebrow}
      title={fireSprinklerPage.moreThanContractor.title}
      body={fireSprinklerPage.moreThanContractor.body}
      ctaLabel={fireSprinklerPage.moreThanContractor.ctaLabel}
      ctaHref={fireSprinklerPage.moreThanContractor.ctaHref}
      image={fireSprinklerPage.moreThanContractor.image}
      imageAlt={fireSprinklerPage.moreThanContractor.imageAlt}
      background="white"
      revealTop={false}
    />

    <!-- ══════════════════════════════════════════════════════════
         §5. SPLITPANEL — Advocacy That Protects Your Investment
            (black-bg split panel, inlined markup — provides both
             the body text column on the left and an image column
             on the right using the SplitPanel visual rhythm but
             with class-name overrides for the black-bg case)
         ══════════════════════════════════════════════════════════ -->
    <section class="rr-band rr-band--reveal-top bg-rr-black text-rr-white fs-split">
      <div class="rr-container">
        <div class="grid gap-10 md:gap-12 lg:gap-16 items-center md:grid-cols-2">
          <div class="order-2 md:order-1">
            <p class="rr-eyebrow mb-5" style="color: rgba(255,255,255,0.7);">{fireSprinklerPage.advocacy.eyebrow}</p>
            <h2
              class="font-display font-black uppercase tracking-tight rr-reveal"
              style="font-size: var(--rr-text-section); line-height: 0.95; color: #fff;"
            >
              {fireSprinklerPage.advocacy.title}
            </h2>
            <p
              class="mt-6 rr-reveal"
              style="font-size: var(--rr-text-lead); color: rgba(255,255,255,0.9);"
              data-reveal-delay="120"
            >
              {fireSprinklerPage.advocacy.body}
            </p>
            <div class="mt-8 rr-reveal" data-reveal-delay="240">
              <a
                href={fireSprinklerPage.advocacy.ctaHref}
                class="av-wgl-btn av-wgl-btn--outline av-wgl-btn--light"
              >
                <span class="av-wgl-btn__text">{fireSprinklerPage.advocacy.ctaLabel}</span>
                <span class="av-wgl-btn__icon">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 14" fill="currentColor" aria-hidden="true"><path d={arrowPath}></path></svg>
                </span>
              </a>
            </div>
          </div>
          <div class="order-1 md:order-2 fs-why-img">
            <div class="overflow-hidden rounded-rr-card bg-rr-black fs-why-img__wrap">
              <img
                src={fireSprinklerPage.advocacy.image}
                alt={fireSprinklerPage.advocacy.imageAlt}
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover fs-why-img__img"
              />
            </div>
          </div>
        </div>
      </div>
    </section>
    <!-- ══════════════════════════════════════════════════════════
         §6. SPLITPANEL — Why Clients Continue to Choose RRFPS
            (revision RRFPS-2: converted from plain black-bg
             to bg-image section identical to §3's accordion
             treatment — overlay matches §3)
         ══════════════════════════════════════════════════════════ -->
    <section class="fs-why">
      <div class="fs-why__bg" aria-hidden="true"></div>

      <div class="fs-why__inner">
        <div class="rr-reveal max-w-3xl mb-12 md:mb-16">
          <p class="rr-eyebrow mb-5" style="color: rgba(255,255,255,0.7);">{fireSprinklerPage.whyClients.eyebrow}</p>
          <h2
            class="font-display font-black uppercase tracking-tight"
            style="font-size: var(--rr-text-section); line-height: 0.95; color: #fff;"
          >
            {fireSprinklerPage.whyClients.title}
          </h2>
          <p
            class="mt-6"
            style="font-size: var(--rr-text-lead); color: rgba(255,255,255,0.9);"
          >
            {fireSprinklerPage.whyClients.body}
          </p>
        </div>

        <div class="grid gap-4 md:gap-6 sm:grid-cols-2 lg:grid-cols-5">
          {fireSprinklerPage.whyClientsValues.map((v, i) => (
            <article
              class="rr-reveal bg-white/10 border border-white/30 rounded-rr-card p-6 flex flex-col"
              data-reveal-delay={i * 100}
            >
              <h3
                class="font-display font-bold tracking-tight"
                style="font-size: var(--rr-text-card); line-height: 1.05; color: #fff;"
              >
                {v.title}
              </h3>
              <p class="mt-3 text-sm leading-relaxed flex-1" style="color: rgba(255,255,255,0.85);">
                {v.body}
              </p>
            </article>
          ))}
        </div>

        <div class="mt-12 rr-reveal">
          <a
            href={fireSprinklerPage.whyClients.ctaHref}
            class="av-wgl-btn av-wgl-btn--outline av-wgl-btn--light"
          >
            <span class="av-wgl-btn__text">{fireSprinklerPage.whyClients.ctaLabel}</span>
            <span class="av-wgl-btn__icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 14" fill="currentColor" aria-hidden="true"><path d={arrowPath}></path></svg>
            </span>
          </a>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════════
         §7. SPLITPANEL — Experience You Can Trust
            (white-bg variant of multi-family.astro §1 pattern)
         ══════════════════════════════════════════════════════════ -->
    <SplitPanel
      eyebrow={fireSprinklerPage.experience.eyebrow}
      title={fireSprinklerPage.experience.title}
      body={fireSprinklerPage.experience.body}
      ctaLabel={fireSprinklerPage.experience.ctaLabel}
      ctaHref={fireSprinklerPage.experience.ctaHref}
      image={fireSprinklerPage.experience.image}
      imageAlt={fireSprinklerPage.experience.imageAlt}
      background="white"
      revealTop={false}
    />

    <!-- ══════════════════════════════════════════════════════════
         §8. INDUSTRIES — bg-image 14-card grid (titles only)
            (about.astro §3 / Benefits pattern, dark image-bg +
             overlay, transparent white-tinted cards)
         ══════════════════════════════════════════════════════════ -->
    <section class="fs-industries">
      <div class="fs-industries__bg" aria-hidden="true"></div>
      <div class="fs-industries__overlay" aria-hidden="true"></div>

      <div class="rr-container relative z-10">
        <div class="rr-reveal max-w-3xl mb-12 md:mb-16">
          <p class="rr-eyebrow mb-5" style="color: rgba(255,255,255,0.7);">{fireSprinklerPage.industries.eyebrow}</p>
          <h2
            class="font-display font-black uppercase tracking-tight"
            style="font-size: var(--rr-text-section); line-height: 0.95; color: #fff;"
          >
            {fireSprinklerPage.industries.title}
          </h2>
          <p
            class="mt-6"
            style="font-size: var(--rr-text-lead); color: rgba(255,255,255,0.9);"
          >
            {fireSprinklerPage.industries.intro}
          </p>
        </div>

        <div class="grid gap-3 md:gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {fireSprinklerPage.industries.items.map((item, i) => (
            <article
              class="rr-reveal bg-white/10 border border-white/25 rounded-rr-card px-5 py-6 flex items-center"
              data-reveal-delay={i * 50}
            >
              <h3
                class="font-display font-bold tracking-tight"
                style="font-size: 18px; line-height: 1.2; color: #fff;"
              >
                {item.title}
              </h3>
            </article>
          ))}
        </div>

        <p
          class="rr-reveal mt-12 max-w-3xl"
          style="font-size: var(--rr-text-lead); color: rgba(255,255,255,0.85);"
        >
          {fireSprinklerPage.industries.closing}
        </p>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════════
         §9. SPLITPANEL — Protecting What Matters Most
            (revision RRFPS-2: flipped from black-bg to white-bg +
             black-text — image swapped to rrfps-protect-what-matters-most.jpg.
             reveal-top kept so the rounded-corner transition matches §8's
             dark-image band above.)
         ══════════════════════════════════════════════════════════ -->
    <SplitPanel
      eyebrow={fireSprinklerPage.protecting.eyebrow}
      title={fireSprinklerPage.protecting.title}
      body={fireSprinklerPage.protecting.body}
      image={fireSprinklerPage.protecting.image}
      imageAlt={fireSprinklerPage.protecting.imageAlt}
      background="white"
      revealTop={true}
    />

    <!-- ══════════════════════════════════════════════════════════
         §10. CLOSING BAND — Ready to Partner + phone
            (revision RRFPS-2: flipped from white-bg + black-text
             to black-bg + white-text. DualCTA immediately below
             remains white per user instruction.)
         ══════════════════════════════════════════════════════════ -->
    <section class="rr-band bg-rr-black text-rr-white">
      <div class="rr-container">
        <div class="rr-reveal max-w-3xl">
          <p class="rr-eyebrow mb-5" style="color: rgba(255,255,255,0.7);">{fireSprinklerPage.closing.eyebrow}</p>
          <h2
            class="font-display font-black uppercase tracking-tight"
            style="font-size: var(--rr-text-section); line-height: 0.95; color: #fff;"
          >
            {fireSprinklerPage.closing.title}
          </h2>
          <p
            class="mt-6"
            style="font-size: var(--rr-text-lead); color: rgba(255,255,255,0.9);"
          >
            {fireSprinklerPage.closing.body}
          </p>
          <div class="mt-6 inline-flex items-center gap-2" style="font-size: var(--rr-text-lead); color: #fff;">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92Z"></path>
            </svg>
            <span><strong>Talk to a life safety expert:</strong> {fireSprinklerPage.closing.phone}</span>
          </div>
        </div>
      </div>
    </section>

    <DualCTA items={fireSprinklerPage.closing.ctaPair} background="white" />

  </div>
</BaseLayout>

<style>
  /* ══════════════════════════════════════════════════════════
   * Reused from inspections.astro (page-title banner + ibox grid
   * + rr-why bg-image band) so the visual language matches that
   * page 1:1. New styles below for the accordion / industries
   * sections and the dark-bg outline button.
   * ══════════════════════════════════════════════════════════ */

  /* ---- §0. Page-title banner ---- */
  .ptbanner {
    position: relative;
    isolation: isolate;
    background-color: #0d0d0b;
  }
  .ptbanner__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-repeat: no-repeat;
    background-position: center bottom;
    z-index: -2;
  }
  /* RRFPS-2: light overlay so the white H1 reads against the photo.
   * Mid-tone translucent dark keeps the page cohesive with §2/§3/§5
   * which are dark, but is *much* lighter than §3's accordion overlay
   * (which uses 35% brightness + 50% black) so the hero still feels
   * photo-forward, not a flat solid panel. */
  .ptbanner__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(13, 13, 11, 0.35) 0%,
      rgba(13, 13, 11, 0.45) 60%,
      rgba(13, 13, 11, 0.55) 100%
    );
    z-index: -1;
  }
  .ptbanner__inner {
    width: 100%;
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: 15px;
    /* RRFPS-2: layout dimensions moved from .ptbanner so the absolutely-
     * positioned bg + overlay can sit underneath. .ptbanner__inner is now
     * the visible content footprint. */
    min-height: 450px;
    margin-bottom: 60px;
    padding-top: 154px;
    padding-bottom: 20px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 20px;
  }
  .ptbanner__title {
    margin: 0;
    color: #ffffff;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: 96px;
    line-height: 104px;
    letter-spacing: -0.05em;
    text-transform: uppercase;
  }
  .ptbanner__breadcrumbs {
    color: #ffffff;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 500;
    font-size: 16px;
    line-height: 30px;
    letter-spacing: -0.04em;
    padding-bottom: 14px;
  }
  .ptbanner__breadcrumbs a {
    color: #ffffff;
    text-decoration: none;
    transition: 0.4s;
  }
  .ptbanner__breadcrumbs a:hover { color: #ffffff99; }
  .ptbanner__divider { margin: 0 10px; }
  .ptbanner__current {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  /* ---- §1. Solutions + ibox grid ---- */
  .sol {
    display: flex;
    max-width: 1600px;
    margin: 0 auto 80px;
  }
  .sol__left { width: 50%; }
  .sol__sticky {
    position: sticky;
    top: 120px;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    padding-right: 0;
  }
  .sol__sticky > * { width: 100%; max-width: 585px; }
  .sol__sticky .av-dblh__subtitle {
    margin-bottom: 23px;
    display: flex;
  }
  .sol__title {
    margin: 0;
    font-family: "Space Grotesk", sans-serif;
    font-size: 56px;
    font-weight: 700;
    text-transform: uppercase;
    line-height: 1.178em;
    padding-bottom: 5px;
    color: #0a0a0a;
  }
  .sol__title span { display: inline-block; }
  .sol__spacer { height: 34px; }
  .sol__cta .av-wgl-btn { display: inline-flex; }
  .sol__cta .av-wgl-btn__text { padding: 17px 35px; }

  .sol__grid {
    width: 50%;
    margin-top: 8px;
    display: flex;
    flex-wrap: wrap;
    row-gap: 30px;
  }
  .sol__grid .ibox { width: 50%; }

  .ibox {
    position: relative;
    display: block;
    text-decoration: none;
    transition: 0.4s;
  }
  .ibox__bg {
    position: absolute;
    inset: 0;
    border: 1px solid #0a0a0a26;
    transition: 0.4s;
    pointer-events: none;
  }
  .ibox:hover { background-color: #fb651b; }
  .ibox:hover .ibox__bg { border-color: transparent; }
  .ibox__icon {
    display: inline-flex;
    background-color: #d41226;
    padding: 16px;
    transition: 0.4s;
  }
  .ibox__icon :global(svg) {
    width: 50px;
    height: 50px;
    fill: #ffffff;
    transition: 0.4s;
  }
  .ibox:hover .ibox__icon { background-color: #ffffff; }
  .ibox:hover .ibox__icon :global(svg) { fill: #0a0a0a; }
  .ibox__content {
    display: flex;
    flex-direction: column;
    min-height: 306px;
    padding: 51px 40px 30px 40px;
  }
  .ibox__title {
    margin: 0;
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(26px, 1.9vw, 30px);
    font-weight: 700;
    text-transform: uppercase;
    line-height: 1.4em;
    color: #0a0a0a;
    transition: 0.4s;
  }
  .ibox__text {
    padding-top: 16px;
    color: #626262;
    font-size: 16px;
    line-height: 1.875;
    transition: 0.4s;
  }
  .ibox:hover .ibox__title,
  .ibox:hover .ibox__text { color: #ffffff; }

  /* ---- §2. Why-red-rocks — solid black bg, no image (RRFPS-2) ---- */
  .fs-why-grid {
    display: grid;
    gap: 48px;
    grid-template-columns: 1fr;
    align-items: start;
  }
  @media (min-width: 1024px) {
    .fs-why-grid {
      gap: 80px;
      grid-template-columns: 5fr 7fr;
    }
  }
  .fs-why-grid__left h2 { color: #ffffff; max-width: 16ch; }
  .fs-why-grid__body { color: rgba(255, 255, 255, 0.85); }

  /* Bullets — used in §2 (renamed from .rr-why__bullets etc.) */
  .rr-why__bullets {
    list-style: none;
    margin: 1.75rem 0 0;
    padding: 0;
    display: grid;
    gap: 14px;
  }
  .rr-why__bullet {
    display: grid;
    grid-template-columns: 24px 1fr;
    align-items: baseline;
    gap: 4px;
    color: rgba(255,255,255,0.92);
    font-size: 17px;
    line-height: 1.55;
  }
  .rr-why__bullet-mark {
    color: #d41226;
    font-size: 18px;
    line-height: 1;
  }

  /* ---- §3. Accordion (5 panels, dark image-bg band) ---- */
  .fs-accordion {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding-block: 110px;
    background-color: #0d0d0b;
  }
  .fs-accordion__bg {
    position: absolute;
    inset: 0;
    background-image: url('/images/rrfps-our-fire-sprinklers-services-2.jpg');
    background-size: cover;
    background-position: center;
    filter: brightness(0.35);
    z-index: -2;
  }
  .fs-accordion::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: -1;
  }
  .fs-accordion__inner {
    width: 100%;
    max-width: 1280px;
    margin-inline: auto;
    padding-inline: 1.25rem;
  }
  @media (min-width: 768px) {
    .fs-accordion__inner { padding-inline: 2.5rem; }
  }
  .fs-accordion .av-dblh__subtitle {
    margin-bottom: 23px;
    display: flex;
    color: rgba(255, 255, 255, 0.7);
  }
  .fs-accordion__title {
    margin: 0 0 60px;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: clamp(36px, 5vw, 56px);
    color: #ffffff;
    text-transform: uppercase;
    line-height: 1.05;
    letter-spacing: -0.02em;
  }
  .fs-accordion__layout {
    display: grid;
    gap: 48px;
    grid-template-columns: 1fr;
  }
  @media (min-width: 1024px) {
    .fs-accordion__layout { grid-template-columns: 5fr 7fr; gap: 80px; }
  }
  .fs-accordion__intro {
    margin: 0;
    font-size: 1.0625rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.85);
  }

  /* Accordion container styles */
  .acc { max-width: 720px; }
  .acc__panel {
    overflow: hidden;
    padding: 15px 0;
    border-top: 1px solid rgba(255, 255, 255, 0.18);
    transition: border-color 0.4s;
  }
  .acc__panel:first-child { border-top: none; }
  .acc__panel:last-child { border-bottom: 1px solid rgba(255, 255, 255, 0.18); }
  .acc__panel:hover,
  .acc__panel.is-active,
  .acc__panel:hover + .acc__panel,
  .acc__panel.is-active + .acc__panel { border-top-color: #d41226; }
  .acc__panel.is-active:last-child,
  .acc__panel:hover:last-child { border-bottom-color: #d41226; }
  .acc__header {
    display: flex;
    align-items: flex-start;
    width: 100%;
    background: none;
    border: none;
    padding: 13px 0;
    cursor: pointer;
    text-align: left;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: 24px;
    letter-spacing: -0.02em;
    color: #ffffff;
  }
  .acc__icon {
    display: inline-flex;
    align-self: flex-start;
    margin: 8px 18px -15px 2px;
    color: #d41226;
    transform: rotate(90deg);
    transition: transform 0.4s;
  }
  .acc__panel.is-active .acc__icon { transform: rotate(-90deg); }
  .acc__icon svg { width: 18px; height: 16px; }
  .acc__content {
    padding: 6px 5px 14px 39px;
    color: rgba(255, 255, 255, 0.85);
    font-size: 16px;
    line-height: 1.65;
  }
  .acc__content p { margin: 0; }
  .acc__bullets {
    list-style: none;
    margin: 14px 0 0;
    padding: 0;
    display: grid;
    gap: 8px;
  }
  .acc__bullet {
    display: grid;
    grid-template-columns: 22px 1fr;
    align-items: baseline;
    gap: 4px;
    color: rgba(255, 255, 255, 0.85);
    font-size: 15px;
    line-height: 1.55;
  }
  .acc__bullet-mark {
    color: #d41226;
    font-size: 16px;
    line-height: 1;
  }
  .acc__footer {
    margin: 14px 0 0 !important;
    font-style: italic;
    color: rgba(255, 255, 255, 0.75);
  }

  /* ---- §5. Advocacy image — taller container to match text column (RRFPS-2)
   * The advocacy image (1280×2275, portrait) is allowed to fill the
   * column at its natural aspect ratio. On desktop the column min-height
   * tracks the text column so left/right line up evenly. */
  .fs-why-img__wrap {
    /* Container grows to at least 480px on desktop so the image column
     * visually matches the text column's natural height. */
    min-height: 360px;
  }
  @media (min-width: 1024px) {
    .fs-why-img__wrap {
      min-height: 520px;
    }
  }
  .fs-why-img__img {
    /* Image fills its wrap, preserves aspect, crops cleanly inside. */
    object-fit: cover;
    object-position: center;
  }

  /* ---- §6. Why-clients — bg-image section (RRFPS-2).
   * Layout mirrors §3 (.fs-accordion) but is lighter-styled — no inner
   * accordion header, just a centered eyebrow / title / body plus a
   * 5-card values grid below. The overlay matches §3's pattern
   * (darker overlay for legibility). */
  .fs-why {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding-block: 110px;
    background-color: #0d0d0b;
  }
  @media (min-width: 768px) { .fs-why { padding-block: 150px; } }
  .fs-why__bg {
    position: absolute;
    inset: 0;
    background-image: url('/images/rrfps-why-clients-continue-to-choose-rrfps.jpg');
    background-size: cover;
    background-position: center;
    filter: brightness(0.35);
    z-index: -2;
  }
  .fs-why::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: -1;
  }
  .fs-why__inner {
    width: 100%;
    max-width: 1280px;
    margin-inline: auto;
    padding-inline: 1.25rem;
    color: #ffffff;
  }
  @media (min-width: 768px) {
    .fs-why__inner { padding-inline: 2.5rem; }
  }

  /* ---- §5 / §6. Outline button on black bg ---- */
  .av-wgl-btn--light {
    color: #ffffff;
    border-color: rgba(255, 255, 255, 0.4);
  }
  .av-wgl-btn--light:hover {
    border-color: #ffffff;
    color: #ffffff;
  }

  /* ---- §8. Industries — bg-image 14-card grid ---- */
  .fs-industries {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding-block: 110px;
    color: #ffffff;
    background-color: #0d0d0b;
  }
  @media (min-width: 768px) { .fs-industries { padding-block: 150px; } }
  .fs-industries__bg {
    position: absolute;
    inset: 0;
    background-image: url('/images/rrfps-serving-colorado-diverse-industries.jpg');
    background-size: cover;
    background-position: center;
    filter: brightness(0.4);
    z-index: -2;
  }
  .fs-industries__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
    z-index: -1;
  }

  /* ---- Responsive ---- */
  @media (max-width: 1200px) {
    .ptbanner__title { font-size: 64px; line-height: 72px; }
    .sol { margin-top: 0; padding: 0 30px; flex-wrap: wrap; }
    .sol__left { width: 100%; }
    .sol__sticky { position: sticky; top: 30px; align-items: flex-start; }
    .sol__sticky > * { max-width: 340px; }
    .sol__title { font-size: 42px; }
    .sol__title span { display: inline; }
    .sol__grid { width: 100%; margin-top: 30px; }
    .sol__grid .ibox { width: 100%; }
    .ibox__content { min-height: 235px; padding: 31px 30px 20px 30px; }
    .ibox__icon :global(svg) { width: 40px; height: 40px; }
    .ibox__title { font-size: 26px; }
    .rr-why { padding-block: 96px; }
  }

  @media (max-width: 767px) {
    .ptbanner__inner { min-height: 320px; padding-top: 120px; }
    .ptbanner__title { font-size: 40px; line-height: 48px; }
    .sol { padding: 0; row-gap: 30px; }
    .sol__sticky { position: relative; top: 0; padding: 0 15px; }
    .sol__title { font-size: 28px; }
    .sol__grid { padding: 0 15px; }
    .ibox__content { min-height: 180px; }
    .rr-why { padding-block: 64px; }
    .rr-why__bullets { gap: 12px; }
    .rr-why__bullet { font-size: 16px; }
    .fs-accordion { padding-block: 70px; }
    .fs-accordion__layout { gap: 32px; }
    .fs-accordion__title { font-size: 28px; margin-bottom: 40px; }
    .fs-industries { padding-block: 70px; }
  }

<script>
  // Accordion controller — same pattern as the rest of the site.
  // Toggles `.is-active` on the panel and `aria-expanded` on the header.
  function initCityAccordions() {
    const panels = document.querySelectorAll<HTMLElement>('.city-page [data-acc-panel]');
    panels.forEach((panel) => {
      const header = panel.querySelector<HTMLButtonElement>('.acc__header');
      if (!header) return;
      header.addEventListener('click', () => {
        const isActive = panel.classList.toggle('is-active');
        header.setAttribute('aria-expanded', isActive ? 'true' : 'false');
        const content = panel.querySelector<HTMLElement>('.acc__content');
        if (content) content.hidden = !isActive;
      });
    });
  }
  document.addEventListener('astro:page-load', initCityAccordions);
</script>
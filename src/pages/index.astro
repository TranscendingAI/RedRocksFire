  function injectInfoboxIcons() {
    document.querySelectorAll<HTMLElement>('[data-icon-slot]').forEach((el) => {
      const i = Number(el.dataset.iconSlot);
      if (INFOBOX_ICONS[i] && !el.firstElementChild) el.innerHTML = INFOBOX_ICONS[i];
    });
  }

  // ── GSAP: fade-ups, counter, word-appear, panel blur ──
  declare const gsap: any;
  declare const ScrollTrigger: any;

  function initHomeMotion() {
    injectInfoboxIcons();

    if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      document.querySelectorAll<HTMLElement>('[data-fade-up]').forEach((el) => {
        el.style.opacity = '1';
        el.style.transform = 'none';
      });
      document.querySelectorAll<HTMLElement>('.statement__word').forEach((el) => {
        el.style.opacity = '1';
      });
      return;
    }

    gsap.registerPlugin(ScrollTrigger);

    document.querySelectorAll('[data-fade-up]').forEach((el) => {
      gsap.to(el, {
        opacity: 1,
        y: 0,
        duration: 0.9,
        ease: 'power3.out',
        scrollTrigger: { trigger: el, start: 'top 88%', once: true },
      });
    });

    // Hero counter 0 → 15
    const counterEl = document.querySelector('[data-counter]');
    if (counterEl) {
      const target = parseInt(counterEl.getAttribute('data-counter-target') || '15', 10);
      const obj = { val: 0 };
      counterEl.textContent = '0';
      gsap.to(obj, {
        val: target,
        duration: 2,
        ease: 'power2.out',
        delay: 0.4,
        onUpdate: () => { counterEl.textContent = String(Math.floor(obj.val)); },
      });
    }

    // Statement words: opacity 0.1 → 1, scrubbed
    const words = document.querySelectorAll('[data-word-appear] .statement__word');
    if (words.length) {
      gsap.to(words, {
        opacity: 1,
        stagger: 0.15,
        ease: 'none',
        scrollTrigger: {
          trigger: '[data-word-appear]',
          start: 'top 85%',
          end: 'bottom 45%',
          scrub: true,
        },
      });
    }

    // Pinned service panels: blur the covered panel (demo's layered effect:
    // brightness 88% contrast 109% blur 5.2px)
    const panels = Array.from(document.querySelectorAll('[data-svc-panel]'));
    panels.forEach((panel, i) => {
      const next = panels[i + 1];
      if (!next) return;
      const inner = panel.querySelector('.svc__panel');
      // The white (--light) panel must never darken to grey — blur only, no brightness/contrast shift.
      const isLight = inner?.classList.contains('svc__panel--light');
      gsap.fromTo(
        inner,
        { filter: 'brightness(100%) contrast(100%) blur(0px)' },
        {
          filter: isLight
            ? 'brightness(100%) contrast(100%) blur(5.2px)'
            : 'brightness(88%) contrast(109%) blur(5.2px)',
          ease: 'none',
          scrollTrigger: {
            trigger: next,
            start: 'top 90%',
            end: 'top 20%',
            scrub: true,
          },
        }
      );
    });

    ScrollTrigger.refresh();
  }

  document.addEventListener('astro:page-load', initHomeMotion);
  if (document.readyState !== 'loading') {
    let tries = 0;
    const tick = () => {
      if (typeof gsap !== 'undefined') initHomeMotion();
      else if (tries++ < 50) setTimeout(tick, 100);
    };
    tick();
  }
</script>

<!-- Swiper 11 (CDN) -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<script is:inline src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
  declare const Swiper: any;

  function initHomeSwipers() {
    if (typeof Swiper === 'undefined') return;

    // Portfolio — 3 columns, 40px gap, square pagination
    const pfEl = document.querySelector('.pf__swiper') as any;
    if (pfEl && !pfEl.swiper) {
      new Swiper(pfEl, {
        slidesPerView: 1,
        spaceBetween: 40,
        loop: true,
        speed: 800,
        grabCursor: true,
        pagination: {
          el: '.pf__pagination',
          clickable: true,
        },
        breakpoints: {
          768: { slidesPerView: 2 },
          1025: { slidesPerView: 3 },
        },
      });
    }

    // Testimonials — 1 per view with PREV / NEXT
    const tmEl = document.querySelector('.tm__swiper') as any;
    if (tmEl && !tmEl.swiper) {
      new Swiper(tmEl, {
        slidesPerView: 1,
        spaceBetween: 30,
        loop: true,
        speed: 800,
        navigation: {
          prevEl: '.tm__nav-prev',
          nextEl: '.tm__nav-next',
        },
      });
    }
  }

  document.addEventListener('astro:page-load', initHomeSwipers);
  let swTries = 0;
  const swTick = () => {
    if (typeof Swiper !== 'undefined') initHomeSwipers();
    else if (swTries++ < 50) setTimeout(swTick, 100);
  };
  swTick();
</script>

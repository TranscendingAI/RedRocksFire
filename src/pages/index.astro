---
/**
 * Home — 1:1 replica of the Avelon "Main Home" demo
 * (https://woocommerce-718927-6369698.cloudwaysapps.com/)
 *
 * Structure and every pixel value below are extracted from the demo's
 * Elementor CSS (reference/…/post-448.css) and theme kit:
 *
 *   1. Hero — bg h1-1.webp · 40px eyebrow · clamp(64px,10.417vw,200px) H1
 *      · red counter box (357px col, 128px value) + GET IN TOUCH
 *   2. Statement — "Building the Future" label · 64px word-appear H2 · MORE ABOUT US
 *   3. Marquee — "Your Vision, Our Build." 170px outlined red stroke
 *   4. Solutions — dark #0D0D0B section, 56px heading, ALL SERVICES,
 *      4 bordered infoboxes (306px content, red icon tiles)
 *   5. Services — 3 pinned #F5F5F5 panels (48px titles, 60px arrow buttons)
 *   6. Clients — 6 masked logos (#0E2F3E → #FB651B hover) over h1-2.webp parallax
 *   7. Presentation band — bg h1-3.webp, red "Precision. Quality. Innovation."
 *      box + logo + mission + WATCH THE PRESENTATION
 *   8. Portfolio — 56px double heading + ALL PROJECTS, 3-col carousel, square pagination
 *   9. Testimonials — 170px white-stroke marquee · h1-4.webp + 36px quotes
 *      carousel (PREV/NEXT) · avatar stack + "200+ happy customers"
 *
 * Fonts: Space Grotesk (headings/buttons/menu), Inter (content).
 * Motion: GSAP + ScrollTrigger (BaseLayout CDN), Swiper 11 (CDN).
 */

import BaseLayout from '../layouts/BaseLayout.astro';

// Shared arrow SVG path (16×14) used by every wgl button + portfolio hover icon
const arrowPath = 'M0 6.78247C0 6.52555 0.102065 6.27914 0.283741 6.09746C0.465416 5.91579 0.711822 5.81372 0.96875 5.81372H12.1927L8.03288 1.65585C7.85097 1.47394 7.74878 1.22723 7.74878 0.969974C7.74878 0.712721 7.85097 0.466004 8.03288 0.284099C8.21478 0.102194 8.4615 0 8.71875 0C8.976 0 9.22272 0.102194 9.40463 0.284099L15.2171 6.0966C15.3073 6.18659 15.3789 6.29349 15.4278 6.41118C15.4766 6.52888 15.5017 6.65505 15.5017 6.78247C15.5017 6.9099 15.4766 7.03607 15.4278 7.15376C15.3789 7.27146 15.3073 7.37836 15.2171 7.46835L9.40463 13.2808C9.22272 13.4628 8.976 13.5649 8.71875 13.5649C8.4615 13.5649 8.21478 13.4628 8.03288 13.2808C7.85097 13.0989 7.74878 12.8522 7.74878 12.595C7.74878 12.3377 7.85097 12.091 8.03288 11.9091L12.1927 7.75122H0.96875C0.711822 7.75122 0.465416 7.64916 0.283741 7.46748C0.102065 7.28581 0 7.0394 0 6.78247Z';

// Diamond divider icon used in double-heading subtitles
const diamondIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="15" height="20" viewBox="0 0 15 20"><path d="M0.660472 19.6191L0.47542 6.53585L13.7437 19.8041L0.660472 19.6191Z"></path><path d="M14.3396 0.939992L14.5246 14.0232L1.25635 0.754941L14.3396 0.939992Z"></path></svg>';

const statementWords = 'we are more than a fire protection company — we are your trusted partner in protecting lives, property, and peace of mind'.split(' ');

const solutions = [
  {
    title: 'Inspections',
    body: 'Code-required annual testing of every life safety system, with comprehensive reports and correction summaries built for your jurisdiction.',
  },
  {
    title: 'Fire Sprinkler Systems',
    body: 'Design, installation, service, and repair of wet, dry, preaction, and standpipe systems, plus fire pumps and retrofits.',
  },
  {
    title: 'Fire Alarm Systems',
    body: 'Fire alarm service and systems backed by 24/7 monitoring, so a problem never goes unnoticed and help is always on the way.',
  },
  {
    title: 'One Vendor Solution',
    body: 'One coordinated team responsible for every life safety system in your building — no gaps, no juggling vendors, no surprises.',
  },
];

const services = [
  {
    number: '01',
    title: 'Inspections & Compliance',
    body: 'By code, fire systems must be tested annually. We thoroughly evaluate every component and deliver the reports jurisdictions require — keeping you compliant and ahead of issues.',
    image: '/images/red-rocks-fire-protection-compliance.jpg',
    imageFirst: false,
  },
  {
    number: '02',
    title: 'Fire Sprinkler Service & Systems',
    body: 'From wet and dry systems to fire pumps, standpipes, and retrofits, our licensed team keeps the systems that protect your property reliable and ready.',
    image: '/images/reed-rocks-fire-protection-fire-sprinkler-service-systems.jpg',
    imageFirst: true,
    light: true,
  },
  {
    number: '03',
    title: 'Fire Alarm & 24/7 Monitoring',
    body: 'We install and service fire alarm systems backed by around-the-clock monitoring of alarms, security systems, elevators, and areas of refuge.',
    image: '/images/red-rocks-fire-alarm-safety.jpg',
    imageFirst: false,
  },
];


const projects = [
  { title: 'MULTI-FAMILY COMMUNITIES', cats: ['inspections', 'monitoring'], image: '/images/red-rocks-fire-protectionmulti-family-communities.jpg' },
  { title: 'COMMERCIAL FACILITIES', cats: ['sprinklers', 'alarms'], image: '/images/red-rocks-fire-protection-commercial-facilities.jpg' },
  { title: 'HEALTHCARE & ASSISTED LIVING', cats: ['compliance', 'monitoring'], image: '/images/red-rocks-fire-protection-healthcare-assited-living.jpg' },
  { title: 'RETAIL & SHOPPING CENTERS', cats: ['inspections', 'backflow'], image: '/images/home/pf-3-1160x820.webp' },
  { title: 'HOTELS & HOSPITALITY', cats: ['alarms', 'suppression'], image: '/images/home/pf-4-1160x820.webp' },
];

const testimonials = [
  {
    name: 'Brandon Cox',
    position: 'Director of Maintenance, Bell Partners, Inc.',
    quote: '“Consistently, they have proven to be honest, reliable, and professional in every aspect of their work. I trust them to do the right thing, not just the easy thing, and that level of integrity is hard to find.”',
  },
  {
    name: 'Melissa Malley',
    position: 'Business Manager, Greystar Residential',
    quote: '“Red Rocks Fire Protection is my preferred and trusted vendor. Their employees are always professional, responsive in a timely manner, and complete all work with 100% satisfaction.”',
  },
  {
    name: 'Jorge Rene Lopez',
    position: 'Maintenance Supervisor',
    quote: '“I have had the pleasure of working with your team for years, and you have always offered the highest level of professionalism. I continue to be satisfied by your services and refer you to others in the industry.”',
  },
  {
    name: 'Alex Martinez',
    position: 'Senior Construction Manager, Greystar',
    quote: '“Their team takes ownership of their work, communicates clearly, and follows through on commitments. They always act with integrity, ensuring the job is done right the first time.”',
  },
];
---

<BaseLayout
  title="Red Rocks Fire Protection Services | One Vendor Life Safety Solution | Colorado"
  description="Colorado's family-owned life safety partner since 2010. One vendor for fire inspections, sprinklers, alarms, monitoring, and compliance across the Denver Front Range."
>
  <div class="av-page">

    <!-- ════════════════════════════════════════════════════════
         1. HERO
         ════════════════════════════════════════════════════════ -->
    <section class="hero">
      <div class="hero__spacer-top" aria-hidden="true"></div>

      <div class="hero__eyebrow-row">
        <h3 class="hero__eyebrow" data-fade-up><span>Your One Vendor Life Safety Solution</span></h3>
      </div>

      <div class="hero__spacer-mid" aria-hidden="true"></div>

      <div class="hero__main-row">
        <h1 class="hero__title" data-fade-up>
          <span>Raising the </span><span>Standard in Fire Safety</span>
        </h1>

        <div class="hero__counter-col">
          <span class="av-delimiter av-delimiter--left" aria-hidden="true"></span>
          <div class="hero__counter-box" data-fade-up>
            <div class="hero__counter">
              <div class="hero__counter-value">
                <span data-counter data-counter-target="200">200</span><span class="hero__counter-suffix">+</span>
              </div>
              <h4 class="hero__counter-title">years of combined experience</h4>
            </div>
            <div class="hero__counter-spacer" aria-hidden="true"></div>
            <a href="/about" class="av-wgl-btn hero__cta">
              <span class="av-wgl-btn__text">get in touch</span>
              <span class="av-wgl-btn__icon">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 14" fill="currentColor" aria-hidden="true"><path d={arrowPath}></path></svg>
              </span>
            </a>
          </div>
          <span class="av-delimiter av-delimiter--right" aria-hidden="true"></span>
        </div>
      </div>

      <div class="hero__spacer-bottom" aria-hidden="true"></div>
    </section>

    <!-- ════════════════════════════════════════════════════════
         2. STATEMENT — Building the Future
         ════════════════════════════════════════════════════════ -->
    <section class="statement">
      <div class="statement__subtitle av-dblh__subtitle">
        <span class="divider-icon" set:html={diamondIcon} />
        <span>Your Partner in Life Safety</span>
      </div>

      <h2 class="statement__text" data-word-appear>
        {statementWords.map((w) => <span class="statement__word">{w}{' '}</span>)}
      </h2>

      <a href="/about" class="av-wgl-btn av-wgl-btn--outline statement__cta">
        <span class="av-wgl-btn__text">MORE ABOUT US</span>
        <span class="av-wgl-btn__icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 14" fill="currentColor" aria-hidden="true"><path d={arrowPath}></path></svg>
        </span>
      </a>
    </section>

    <!-- ════════════════════════════════════════════════════════
         3.–6. wrapper with h1-2.webp parallax layer at its bottom
         ════════════════════════════════════════════════════════ -->
    <div class="midwrap">

      <!-- 3. MARQUEE — outlined red stroke -->
      <div class="marquee-spacer-top" aria-hidden="true"></div>
      <div class="av-loop marquee" aria-hidden="true">
        {[0, 1, 2].map(() => (
          <div class="av-loop__track">
            <h3 class="marquee__text">One Vendor. Total Life Safety Confidence.&nbsp; One Vendor. Total Life Safety Confidence.</h3>
          </div>
        ))}
      </div>
      <div class="marquee-spacer-bottom" aria-hidden="true"></div>

      <!-- 4. SOLUTIONS — dark section -->
      <section class="solutions">
        <div class="solutions__inner">
          <div class="solutions__head">
            <div class="solutions__head-left" data-fade-up>
              <div class="av-dblh__subtitle">
                <span class="divider-icon" set:html={diamondIcon} />
                <span>One Vendor, Total Coverage</span>
              </div>
              <h3 class="av-dblh__title solutions__title">Comprehensive Life Safety, One Trusted Partner</h3>
            </div>
            <div class="solutions__head-right" data-fade-up>
              <a href="/services" class="av-wgl-btn av-wgl-btn--ghost-light">
                <span class="av-wgl-btn__text">ALL SERVICES</span>
                <span class="av-wgl-btn__icon">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 14" fill="currentColor" aria-hidden="true"><path d={arrowPath}></path></svg>
                </span>
              </a>
            </div>
          </div>

          <div class="solutions__spacer" aria-hidden="true"></div>

          <div class="solutions__grid">
            {solutions.map((s, i) => (
              <a href="/about" class="infobox" data-fade-up>
                <span class="infobox__bg" aria-hidden="true"></span>
                <span class="infobox__icon" data-icon-slot={i} aria-hidden="true"></span>
                <span class="infobox__content">
                  <h4 class="infobox__title">{s.title}</h4>
                  <span class="infobox__text">{s.body}</span>
                </span>
              </a>
            ))}
          </div>

          <div class="solutions__spacer-bottom" aria-hidden="true"></div>
        </div>
      </section>

      <!-- 5. SERVICES — heading + pinned panels -->
      <section class="svc">
        <div class="svc__head" data-fade-up>
          <div class="av-dblh__subtitle">
            <span class="divider-icon svc__heart" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="20" height="20" fill="currentColor"><path d="M116.65 219.35a15.68 15.68 0 0 0 22.65 0l96.75-99.83c28.15-29 26.5-77.1-4.91-103.88C203.75-7.7 163-3.5 137.86 22.44L128 32.58l-9.85-10.14C93.05-3.5 52.25-7.7 24.86 15.64c-31.41 26.78-33 74.85-5 103.88zm143.92 100.49h-48l-7.08-14.24a27.39 27.39 0 0 0-25.66-17.78h-71.71a27.39 27.39 0 0 0-25.66 17.78l-7 14.24h-48A27.45 27.45 0 0 0 0 347.3v137.25A27.44 27.44 0 0 0 27.43 512h233.14A27.45 27.45 0 0 0 288 484.55V347.3a27.45 27.45 0 0 0-27.43-27.46zM144 468a52 52 0 1 1 52-52 52 52 0 0 1-52 52zm355.4-115.9h-60.58l22.36-50.75c2.1-6.65-3.93-13.21-12.18-13.21h-75.59c-6.3 0-11.66 3.9-12.5 9.1l-16.8 106.93c-1 6.3 4.88 11.89 12.5 11.89h62.31l-24.2 83c-1.89 6.65 4.2 12.9 12.23 12.9a13.26 13.26 0 0 0 10.92-5.25l92.4-138.91c4.88-6.91-1.16-15.7-10.87-15.7zM478.08.33L329.51 23.17C314.87 25.42 304 38.92 304 54.83V161.6a83.25 83.25 0 0 0-16-1.7c-35.35 0-64 21.48-64 48s28.65 48 64 48c35.2 0 63.73-21.32 64-47.66V99.66l112-17.22v47.18a83.25 83.25 0 0 0-16-1.7c-35.35 0-64 21.48-64 48s28.65 48 64 48c35.2 0 63.73-21.32 64-47.66V32c0-19.48-16-34.42-33.92-31.67z"></path></svg>
            </span>
            <span>End-to-End Life Safety Service</span>
          </div>
          <h3 class="av-dblh__title svc__title">Life Safety Services You Can Rely On</h3>
        </div>

        <div class="svc__stack">
          {services.map((s) => (
            <div class="svc__panel-wrap" data-svc-panel>
              <div class:list={['svc__panel', s.imageFirst && 'svc__panel--image-first', s.light && 'svc__panel--light']}>
                <div class="svc__content">
                  <div class="svc__dblh">
                    <div class="svc__number">{s.number}</div>
                    <h3 class="svc__panel-title">{s.title}</h3>
                  </div>
                  <div class="svc__divider" aria-hidden="true"></div>
                  <p class="svc__body">{s.body}</p>
                  <a href="/about" class="av-wgl-btn svc__more" aria-label={`More about ${s.title}`}>
                    <span class="av-wgl-btn__icon">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 14" fill="currentColor" aria-hidden="true"><path d={arrowPath}></path></svg>
                    </span>
                  </a>
                </div>
                <div class="svc__image">
                  <img src={s.image} alt={s.title} loading="lazy" />
                </div>
              </div>
            </div>
          ))}
        </div>

      </section>
    </div>

    <!-- ════════════════════════════════════════════════════════
         7. PRESENTATION BAND — h1-3.webp
         ════════════════════════════════════════════════════════ -->
    <section class="band">
      <div class="band__spacer-top" aria-hidden="true"></div>
      <div class="band__divider" aria-hidden="true"></div>

      <div class="band__row">
        <span class="av-delimiter av-delimiter--left" aria-hidden="true"></span>

        <div class="band__redbox">
          <h2 class="band__heading">Safety.<br />Advocacy.<br />Trust.</h2>
        </div>

        <div class="band__logo">
          <img src="/images/home/about_logo.webp" alt="Red Rocks Fire Protection emblem" loading="lazy" />
        </div>

        <p class="band__text">We exist to protect lives and property — proactively, accountably, and through one trusted partner responsible for it all.</p>

        <a href="/about" class="av-wgl-btn band__cta">
          <span class="av-wgl-btn__text">read our story</span>
          <span class="av-wgl-btn__icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960" width="26" height="26" fill="currentColor" aria-hidden="true"><path d="M320-200v-560l440 280-440 280Z"></path></svg>
          </span>
        </a>

        <span class="av-delimiter av-delimiter--right" aria-hidden="true"></span>
      </div>

      <div class="band__divider" aria-hidden="true"></div>
      <div class="band__spacer-bottom" aria-hidden="true"></div>
    </section>

    <!-- ════════════════════════════════════════════════════════
         8. PORTFOLIO
         ════════════════════════════════════════════════════════ -->
    <section class="pf">
      <div class="pf__head-wrap">
        <div class="pf__spacer-top" aria-hidden="true"></div>
        <div class="pf__head" data-fade-up>
          <div class="pf__head-left">
            <div class="av-dblh__subtitle">
              <span class="divider-icon" set:html={diamondIcon} />
              <span>Who We Serve</span>
            </div>
            <h3 class="av-dblh__title">Protecting Communities and Businesses Across Colorado</h3>
          </div>
          <a href="/services" class="av-wgl-btn av-wgl-btn--outline pf__all">
            <span class="av-wgl-btn__text">all services</span>
            <span class="av-wgl-btn__icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 14" fill="currentColor" aria-hidden="true"><path d={arrowPath}></path></svg>
            </span>
          </a>
        </div>
      </div>

      <div class="pf__spacer-mid" aria-hidden="true"></div>

      <div class="pf__carousel" data-fade-up>
        <div class="swiper pf__swiper">
          <div class="swiper-wrapper">
            {projects.map((p) => (
              <div class="swiper-slide">
                <article class="pf-item">
                  <a href="/services" class="pf-item__image" aria-label={p.title}>
                    <img src={p.image} alt={p.title} loading="lazy" decoding="async" />
                    <span class="pf-item__icon" aria-hidden="true">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 14" fill="currentColor"><path d={arrowPath}></path></svg>
                    </span>
                  </a>
                  <div class="pf-item__description">
                    <h5 class="pf-item__title"><a href="/services">{p.title}</a></h5>
                    <div class="pf-item__cats">
                      {p.cats.map((c) => <a href="/services" class="pf-item__cat">{c}</a>)}
                    </div>
                  </div>
                </article>
              </div>
            ))}
          </div>
        </div>
        <div class="pf__pagination-wrap">
          <div class="pf__pagination"></div>
        </div>
      </div>

      <div class="pf__spacer-bottom" aria-hidden="true"></div>
    </section>

    <!-- ════════════════════════════════════════════════════════
         9. TESTIMONIALS
         ════════════════════════════════════════════════════════ -->
    <section class="tm">
      <div class="av-loop tm__marquee" aria-hidden="true">
        {[0, 1, 2].map(() => (
          <div class="av-loop__track">
            <h3 class="tm__marquee-text">
              WHAT CLIENTS SAY ABOUT US&nbsp; WHAT CLIENTS SAY ABOUT US&nbsp; WHAT CLIENTS SAY ABOUT US&nbsp; WHAT CLIENTS SAY ABOUT US&nbsp;
            </h3>
          </div>
        ))}
      </div>

      <div class="tm__row">
        <div class="tm__image">
          <img src="/images/home/h1-4.webp" alt="Red Rocks Fire Protection technician on site" loading="lazy" />
        </div>

        <div class="tm__col">
          <div class="tm__carousel">
            <div class="swiper tm__swiper">
              <div class="swiper-wrapper">
                {testimonials.map((t) => (
                  <div class="swiper-slide">
                    <div class="tm-item">
                      <div class="tm-item__quote">{t.quote}</div>
                      <div class="tm-item__author">
                        <h3 class="tm-item__name">{t.name}</h3>
                        <span class="tm-item__position">{t.position}</span>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
            <div class="tm__nav">
              <button type="button" class="tm__nav-btn tm__nav-prev">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 14" fill="currentColor" style="transform: scaleX(-1)" aria-hidden="true"><path d={arrowPath}></path></svg>
                <span>PREV</span>
              </button>
              <button type="button" class="tm__nav-btn tm__nav-next">
                <span>NEXT</span>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 14" fill="currentColor" aria-hidden="true"><path d={arrowPath}></path></svg>
              </button>
            </div>
          </div>

          <div class="tm__spacer" aria-hidden="true"></div>

          <div class="tm__customers">
            {[1, 2, 3].map((n) => (
              <img
                src={`/images/home/testimonials-logo-${n}.webp`}
                alt=""
                class="tm__avatar"
                loading="lazy"
              />
            ))}
            <h2 class="tm__customers-label">trusted across Colorado</h2>
          </div>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  /* ══════════════════════════════════════════════════════════
   * 1. HERO
   * ══════════════════════════════════════════════════════════ */
  .hero {
    position: relative;
    overflow: hidden;
    background-image: url('/images/red-rocks-fire-protection-home-hero.jpg');
    background-position: center center;
    background-size: cover;
  }
  /* Subtle dark overlay to lift the white text off the image */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.3);
    z-index: 1;
    pointer-events: none;
  }
  .hero__eyebrow-row,
  .hero__main-row { position: relative; z-index: 2; }
  .hero__spacer-top { height: 200px; }
  .hero__spacer-mid { height: 333px; }
  .hero__spacer-bottom { height: 69px; }

  .hero__eyebrow-row {
    padding-left: 3.1%;
    padding-right: 3.6%;
  }
  .hero__eyebrow {
    max-width: 400px;
    font-size: 40px;
    text-transform: uppercase;
    line-height: 1em;
    margin: 0;
  }
  .hero__eyebrow span { color: #ffffff; }

  .hero__main-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid #ffffff66;
    border-bottom: 1px solid #ffffff66;
    padding-left: 3.1%;
    padding-right: 3.6%;
  }
  .hero__title {
    max-width: 1050px;
    margin: 10px 0 0 0;
    font-size: clamp(64px, 10.417vw, 200px);
    text-transform: uppercase;
    line-height: 0.8em;
    letter-spacing: -0.05em;
    color: #ffffff;
  }
  .hero__title span { display: block; color: #ffffff; }

  .hero__counter-col {
    position: relative;
    width: 357px;
    flex-shrink: 0;
    align-self: stretch;
    display: flex;
  }
  .hero__counter-box {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 359px;
    margin: -1px 0;
    padding: 16px 20px 20px 20px;
    background-color: var(--av-primary);
    position: relative;
    z-index: 5;
  }
  .hero__counter-col .av-delimiter {
    top: -500%;
    bottom: auto;

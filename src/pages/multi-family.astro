---
/**
 * Redirect stub — /multi-family/ → /multi-family-management-companies/.
 *
 * The page was renamed in 2026-07 (file:
 * `multi-family-management-companies.astro`). Any inbound links to
 * the old short URL (search engines, prior marketing collateral,
 * saved bookmarks) should land on the new page rather than 404.
 *
 * This page issues a meta-refresh redirect (works without server
 * config and survives Astro's static-rendering model), and a
 * `<link rel="canonical">` plus a visible fallback link so the redirect
 * is correct for humans, search engines, and screen readers alike.
 */

const NEW_URL = '/multi-family-management-companies/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Redirecting… | Red Rocks Fire Protection</title>
    <meta name="description" content="This page has moved. You'll be redirected to the Multi-Family Management Companies page." />
    {/* Meta refresh — primary redirect mechanism (works on every Astro output adapter) */}
    <meta http-equiv="refresh" content={`0; url=${NEW_URL}`} />
    {/* Canonical signal for search engines */}
    <link rel="canonical" href={NEW_URL} />
  </head>
  <body style="margin:0; background:#000; color:#fff; font-family:'Inter',system-ui,sans-serif; min-height:100vh; display:flex; align-items:center; justify-content:center; padding:2rem;">
    <main style="text-align:center; max-width:32rem;">
      <h1 style="font-size:clamp(2rem, 4vw, 2.75rem); margin:0 0 1rem; text-transform:uppercase;">This page has moved.</h1>
      <p style="margin:0 0 1.5rem; opacity:0.75;">
        Our Multi-Family content now lives at the longer URL.
      </p>
      <a
        href={NEW_URL}
        style="display:inline-block; padding:0.85rem 1.6rem; border-radius:999px; background:#D31428; color:#fff; text-decoration:none; font-weight:600;"
      >
        Continue to the new page →
      </a>
    </main>
  </body>
</html>

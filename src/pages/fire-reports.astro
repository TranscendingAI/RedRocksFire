---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Fire Reports Lookup — Red Rocks Fire Protection"
  description="Search Red Rocks Fire Protection fire reports by property address or company name, then open or download the report PDF."
>
  <!-- ══════════════════════════════════════════════════════════
       PAGE-TITLE BANNER (replicated from inspections.astro §0)
       ══════════════════════════════════════════════════════════ -->
  <div
    class="ptbanner"
    style="background-image: url('/images/red-rocks-fire-protection-inspection-hero.jpg');"
  >
    <div class="ptbanner__inner">
      <h1 class="ptbanner__title">Fire Report Lookup</h1>
      <div class="ptbanner__breadcrumbs">
        <a href="/">Home</a>
        <span class="ptbanner__divider">-</span>
        <span class="ptbanner__current">FIRE REPORT LOOKUP</span>
      </div>
    </div>
  </div>

  <section class="fr">
    <div class="rr-container">
      <p class="fr__lead">
        Search for a fire report by property address or company name.
        Then open the report in your browser or download the PDF.
      </p>

      <form id="fr-search" class="fr__form">
        <label class="fr__field">
          <span class="fr__label">Property address</span>
          <input type="text" id="q-address" placeholder="e.g. 123 Main St" autocomplete="off" />
        </label>
        <label class="fr__field">
          <span class="fr__label">Company name</span>
          <input type="text" id="q-company" placeholder="e.g. Acme Property Group" autocomplete="off" />
        </label>
        <div class="fr__actions">
          <button type="submit" class="fr__btn fr__btn--primary">Search</button>
          <button type="button" id="q-clear" class="fr__btn fr__btn--ghost">Clear</button>
        </div>
      </form>

      <p id="fr-status" class="fr__status">Enter an address or company name above to search.</p>
      <ul id="fr-results" class="fr__results"></ul>
    </div>
  </section>
</BaseLayout>

<script>
  import { supabase, REPORTS_BUCKET } from '../lib/supabase';

  function esc(s: string | null | undefined) {
    return (s ?? '').replace(/[&<>"']/g, (c) => (
      { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string
    ));
  }

  function fmtDate(d: string | null) {
    if (!d) return '—';
    const [y, m, day] = d.split('T')[0].split('-');
    if (!y) return d;
    return `${m}/${day}/${y}`;
  }

  async function openPdf(path: string, download: boolean, fileName: string) {
    const { data, error } = await supabase.storage
      .from(REPORTS_BUCKET)
      .createSignedUrl(path, 60, download ? { download: fileName } : undefined);
    if (error || !data) {
      alert('Could not open file: ' + (error?.message ?? 'unknown error'));
      return;
    }
    if (download) {
      const a = document.createElement('a');
      a.href = data.signedUrl;
      a.download = fileName;
      document.body.appendChild(a);
      a.click();
      a.remove();
    } else {
      window.open(data.signedUrl, '_blank', 'noopener');
    }
  }

  // Icons (inline SVG — no icon-runtime dependency)
  const openIcon = `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>`;
  const downloadIcon = `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5 5 5-5"/><path d="M12 15V3"/></svg>`;

  function render(results: HTMLElement, status: HTMLElement, rows: any[]) {
    results.innerHTML = '';
    if (!rows.length) {
      status.textContent = 'No reports matched your search.';
      return;
    }
    status.textContent = `${rows.length} report${rows.length === 1 ? '' : 's'} found`;

    for (const r of rows) {
      const loc = [r.address, r.city, r.state, r.zip].filter(Boolean).join(', ');
      const li = document.createElement('li');
      li.className = 'fr-card';
      li.innerHTML = `
        <div class="fr-card__main">
          <p class="fr-card__client">${esc(r.client_name)}</p>
          <p class="fr-card__loc">${esc(loc) || '—'}</p>
          <p class="fr-card__meta">
            <span>Date of test: ${fmtDate(r.test_date)}</span>
            <span>File: ${esc(r.file_name)}</span>
          </p>
        </div>
        <div class="fr-card__actions">
          <button class="fr-icon" data-act="open" title="Open in browser" aria-label="Open report in browser">${openIcon}</button>
          <button class="fr-icon" data-act="download" title="Download PDF" aria-label="Download report PDF">${downloadIcon}</button>
        </div>`;
      li.querySelector('[data-act="open"]')!
        .addEventListener('click', () => openPdf(r.pdf_path, false, r.file_name));
      li.querySelector('[data-act="download"]')!
        .addEventListener('click', () => openPdf(r.pdf_path, true, r.file_name));
      results.appendChild(li);
    }
  }

  function init() {
    const form = document.getElementById('fr-search') as HTMLFormElement | null;
    if (!form) return; // not on this page
    const results = document.getElementById('fr-results') as HTMLElement;
    const status = document.getElementById('fr-status') as HTMLElement;
    const addressEl = document.getElementById('q-address') as HTMLInputElement;
    const companyEl = document.getElementById('q-company') as HTMLInputElement;

    async function runSearch() {
      const address = addressEl.value.trim();
      const company = companyEl.value.trim();
      if (!address && !company) {
        results.innerHTML = '';
        status.textContent = 'Enter an address or company name above to search.';
        return;
      }
      status.textContent = 'Searching…';
      results.innerHTML = '';

      let q = supabase
        .from('fire_reports')
        .select('*')
        .order('created_at', { ascending: false })
        .limit(200);
      if (address) q = q.ilike('address', `%${address}%`);
      if (company) q = q.ilike('client_name', `%${company}%`);

      const { data, error } = await q;
      if (error) {
        status.textContent = 'Something went wrong. Please try again.';
        return;
      }
      render(results, status, data ?? []);
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      runSearch();
    });
    document.getElementById('q-clear')!.addEventListener('click', () => {
      addressEl.value = '';
      companyEl.value = '';
      results.innerHTML = '';
      status.textContent = 'Enter an address or company name above to search.';
    });
  }

  // Runs on initial load AND after every ClientRouter (SPA) navigation.
  document.addEventListener('astro:page-load', init);
</script>

<style>
  /* ---- Page-title banner (copied from inspections.astro §0) ---- */
  .ptbanner {
    background-size: cover;
    background-repeat: no-repeat;
    background-position: center bottom;
    min-height: 450px;
    margin-bottom: 60px;
    padding-top: 154px;
    padding-bottom: 20px;
    display: flex;
    align-items: flex-end;
  }
  .ptbanner__inner {
    width: 100%;
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: 15px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 20px;
  }
  .ptbanner__title {
    margin: 0;
    color: #ffffff;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: 96px;
    line-height: 104px;
    letter-spacing: -0.05em;
    text-transform: uppercase;
  }
  .ptbanner__breadcrumbs {
    color: #ffffff;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 500;
    font-size: 16px;
    line-height: 30px;
    letter-spacing: -0.04em;
    padding-bottom: 14px;
  }
  .ptbanner__breadcrumbs a {
    color: #ffffff;
    text-decoration: none;
    transition: 0.4s;
  }
  .ptbanner__breadcrumbs a:hover { color: #ffffff99; }
  .ptbanner__divider { margin: 0 10px; }
  .ptbanner__current {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .fr {
    padding-top: 0;
    padding-bottom: var(--rr-space-24);
  }
  .fr__lead {
    font-size: var(--rr-text-lead);
    color: var(--rr-black);
    margin: 0;
  }

  .fr__form {
    margin-top: 2.5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem 1.25rem;
    align-items: end;
    max-width: 820px;
  }
  .fr__field { display: flex; flex-direction: column; gap: 0.45rem; }
  .fr__label { font-size: 0.85rem; font-weight: 600; }
  .fr__form input {
    font: inherit;
    padding: 0.8rem 0.9rem;
    border: 1px solid var(--rr-grey-soft);
    border-radius: 12px;
    background: var(--rr-white);
  }
  .fr__form input:focus { border-color: var(--rr-red); outline: none; }

  .fr__actions {
    grid-column: 1 / -1;
    display: flex;
    gap: 0.75rem;
  }
  .fr__btn {
    font: inherit;
    font-weight: 700;
    border-radius: 12px;
    padding: 0.8rem 1.6rem;
    cursor: pointer;
    border: 1px solid transparent;
    transition: background var(--rr-dur-fast), border-color var(--rr-dur-fast), color var(--rr-dur-fast);
  }
  .fr__btn--primary { color: var(--rr-white); background: var(--rr-red); }
  .fr__btn--primary:hover { background: var(--rr-red-hover); }
  .fr__btn--ghost { color: var(--rr-black); background: transparent; border-color: var(--rr-grey-soft); }
  .fr__btn--ghost:hover { border-color: var(--rr-red); color: var(--rr-red); }

  .fr__status {
    margin: 2rem 0 1rem;
    font-size: 0.9rem;
    color: var(--rr-grey);
  }

  .fr__results {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.25rem;
  }
  /* Result cards are injected via JS, so their styles must be :global to apply. */
  :global(.fr-card) {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 1.5rem 1.5rem 4rem;
    border: 1px solid var(--rr-border-lt);
    border-radius: var(--rr-radius-card);
    background: var(--rr-white);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.06);
    transition: box-shadow var(--rr-dur-fast), transform var(--rr-dur-fast);
  }
  :global(.fr-card:hover) {
    box-shadow: 0 14px 34px rgba(0, 0, 0, 0.12);
    transform: translateY(-2px);
  }
  :global(.fr-card__client) { margin: 0; font-weight: 700; font-size: 1.15rem; }
  :global(.fr-card__loc) { margin: 0.4rem 0 0; font-size: 0.95rem; color: var(--rr-black); }
  :global(.fr-card__meta) {
    margin: 0.85rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    font-size: 0.8rem;
    color: var(--rr-grey);
  }
  :global(.fr-card__actions) {
    position: absolute;
    bottom: 1.15rem;
    right: 1.25rem;
    display: flex;
    gap: 0.5rem;
  }
  :global(.fr-icon) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    color: var(--rr-black);
    background: var(--rr-bg-light);
    border: 1px solid var(--rr-grey-soft);
    border-radius: 10px;
    cursor: pointer;
    transition: background var(--rr-dur-fast), color var(--rr-dur-fast), border-color var(--rr-dur-fast);
  }
  :global(.fr-icon:hover) {
    color: var(--rr-white);
    background: var(--rr-red);
    border-color: var(--rr-red);
  }

  @media (max-width: 1200px) {
    .ptbanner__title { font-size: 64px; line-height: 72px; }
  }
  @media (max-width: 767px) {
    .ptbanner { min-height: 320px; padding-top: 120px; }
    .ptbanner__title { font-size: 40px; line-height: 48px; }
  }

  @media (max-width: 640px) {
    .fr__form { grid-template-columns: 1fr; }
    .fr__results { grid-template-columns: 1fr; }
  }
</style>

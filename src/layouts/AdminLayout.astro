---
/**
 * Minimal, self-contained layout for the admin area.
 *
 * Deliberately does NOT use BaseLayout — no marketing header/footer and no
 * ClientRouter, so the admin pages load fresh with normal script execution.
 * Marked noindex so the login/dashboard never show up in search results.
 */
import '../styles/global.css';

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>
  </head>
  <body class="admin-body">
    <slot />
  </body>
</html>

<style is:global>
  .admin-body {
    background: var(--rr-bg-light);
    color: var(--rr-black);
    font-family: var(--rr-font-body);
    min-height: 100vh;
    margin: 0;
  }
</style>

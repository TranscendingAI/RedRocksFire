---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  /** Absolute URL of the canonical page (used for og:url + rel=canonical). */
  canonical?: string;
  /** Absolute URL of the social-share image. */
  image?: string;
  /** og:type — "website" (default) or "article" for blog posts. */
  type?: 'website' | 'article';
  /** ISO publish date — used for article:published_time. */
  publishDate?: string;
  /** ISO modified date — used for article:modified_time. */
  modifiedDate?: string;
  /** Author byline for og:article:author. */
  author?: string;
  /** Pre-built JSON-LD payload (stringified). Inserted verbatim. */
  schema?: string;
}

const {
  title,
  description = 'Red Rocks Fire Protection — Colorado fire safety inspections, sprinkler systems, and 24/7 monitoring.',
  canonical,
  image,
  type = 'website',
  publishDate,
  modifiedDate,
  author,
  schema,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#000000" />
    {canonical && <link rel="canonical" href={canonical} />}
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {image && <meta property="og:image" content={image} />}
    <meta property="og:site_name" content="Red Rocks Fire Protection" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {image && <meta name="twitter:image" content={image} />}
    {type === 'article' && publishDate && (
      <meta property="article:published_time" content={publishDate} />
    )}
    {type === 'article' && modifiedDate && (
      <meta property="article:modified_time" content={modifiedDate} />
    )}
    {type === 'article' && author && (
      <meta property="article:author" content={author} />
    )}
    {schema && <script type="application/ld+json" set:html={schema} />}
    <ClientRouter />
    <title>{title}</title>
  </head>
  <body class="bg-rr-bg-light text-rr-black min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    {/* GSAP + ScrollTrigger — loaded on every page so sections that want
     * scroll-triggered reveals work without each page re-loading them.
     * is:inline keeps them as plain <script src> tags (not bundled) so
     * they execute before any module scripts that depend on `gsap`.
     */}
    <script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/gsap.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/ScrollTrigger.min.js"></script>

    {/* Reveal-on-scroll observer — design.md §5
 * Re-runs on every astro:page-load event so SPA-navigated pages
 * (via ClientRouter) also get their content revealed.
 */}
    <script>
      function initRevealObserver() {
        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        if (reduceMotion) {
          // No motion: show final state immediately
          document.querySelectorAll('.rr-reveal').forEach((el) => el.classList.add('is-visible'));
          return;
        }

        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.15, rootMargin: '0px 0px -10% 0px' }
        );

        document.querySelectorAll('.rr-reveal').forEach((el) => observer.observe(el));
      }

      // Runs on initial load AND after every ClientRouter navigation.
      document.addEventListener('astro:page-load', initRevealObserver);
    </script>
  </body>
</html>
---
/**
 * Header — 1:1 replica of the Avelon demo header (Elementor template 473),
 * with one addition: SERVICES is now a hover/click dropdown trigger (no
 * own-page navigation). Its dropdown menu lists "Services Overview"
 * (-> /services) and "Inspections" (-> /inspections).
 *
 * Existing structure preserved:
 *   Desktop:
 *     [ red logo box max(251px, 16.1%) ] [ right column:
 *         row 1 — social icons (left) · "Mon - Sat: 7.00am - 19.00pm" (right)
 *         row 2 — nav (94px tall, Space Grotesk 700 16px white) · CART · SEARCH ]
 *   Mobile (<1025px): 70px bar — logo left, white round hamburger right.
 *
 * Source of truth for nav data lives HERE so future nav edits are 1 place.
 */

interface SubItem {
  href: string;
  label: string;
}

interface NavItem {
  href?: string;
  label: string;
  /** If set, this nav item opens a dropdown of children instead of linking anywhere. */
  children?: SubItem[];
}

/**
 * Industries We Serve dropdown — 14 sub-pages, one per vertical named in
 * the Brand Strategy §5.5. Pages all exist as light placeholders (or in
 * the case of /multi-family, a fully-built landing page); when each one's
 * full content lands, no nav change is needed.
 */
const industriesNav = [
  { href: '/multi-family',                       label: 'Multi-Family Management' },
  { href: '/commercial-property',                label: 'Commercial Property' },
  { href: '/religious-institutions',             label: 'Religious Institutions' },
  { href: '/assisted-living',                   label: 'Assisted Living' },
  { href: '/education',                         label: 'Education / Universities' },
  { href: '/warehouse-industrial',               label: 'Warehouse / Industrial' },
  { href: '/hoa-management',                    label: 'HOA Management' },
  { href: '/hotels-hospitality',                label: 'Hotels & Hospitality' },
  { href: '/retail',                            label: 'Retail & Shopping Centers' },
  { href: '/restaurants',                        label: 'Restaurants & Food Trucks' },
  { href: '/financial',                         label: 'Financial Institutions' },
  { href: '/automotive',                        label: 'Automotive Dealerships' },
  { href: '/data-centers',                      label: 'Data Centers' },
  { href: '/general-contractors',               label: 'General Contractors' },
] as const satisfies ReadonlyArray<SubItem>;

const navItems: NavItem[] = [
  { href: '/about', label: 'ABOUT' },
  {
    label: 'SERVICES',
    children: [
      { href: '/services', label: 'Services Overview' },
      { href: '/inspections', label: 'Inspections' },
    ],
  },
  {
    label: 'INDUSTRIES WE SERVE',
    children: [...industriesNav],
  },
  { href: '/testimonials', label: 'TESTIMONIALS' },
  { href: '/service-areas', label: 'SERVICE AREAS' },
  { href: '/blog', label: 'BLOG' },
  { href: '/contact', label: 'CONTACT' },
];

const currentPath = typeof Astro !== 'undefined' ? Astro.url.pathname : '/';

/**
 * Match logic
 *  - Plain href items: current iff currentPath === href
 *  - Items with children: current iff currentPath matches any child href
 *    (so highlighting rolls up to the parent). This lets a top-level item
 *    styled as "active" stay active across /services, /inspections, etc.
 */
function isCurrent(item: NavItem): boolean {
  if (item.children && item.children.length) {
    return item.children.some((c) => currentPath === c.href || currentPath.startsWith(c.href + '/'));
  }
  if (!item.href) return false;
  if (item.href === '/') return currentPath === '/' || currentPath === '';
  return currentPath === item.href || currentPath.startsWith(item.href + '/');
}

const socials = [
  {
    href: 'https://x.com/', label: 'X-twitter',
    path: 'M389.2 48h70.6L305.6 224.2 487 464H345L233.7 318.6 106.5 464H35.8L200.7 275.5 26.8 48H172.4L272.9 180.9 389.2 48zM364.4 421.8h39.1L151.1 88h-42L364.4 421.8z',
    viewBox: '0 0 512 512',
  },
  {
    href: 'https://www.facebook.com/', label: 'Facebook',
    path: 'M80 299.3V512H196V299.3h86.5l18-97.8H196V166.9c0-51.7 20.3-71.5 72.7-71.5c16.3 0 29.4 .4 37 1.2V7.9C291.4 4 256.4 0 236.2 0C129.3 0 80 50.5 80 159.4v42.1H14v97.8H80z',
    viewBox: '0 0 320 512',
  },
  {
    href: 'https://www.instagram.com/', label: 'Instagram',
    path: 'M224.1 141c-63.6 0-114.9 51.3-114.9 114.9s51.3 114.9 114.9 114.9S339 319.5 339 255.9 287.7 141 224.1 141zm0 189.6c-41.1 0-74.7-33.5-74.7-74.7s33.5-74.7 74.7-74.7 74.7 33.5 74.7 74.7-33.6 74.7-74.7 74.7zm146.4-194.3c0 14.9-12 26.8-26.8 26.8-14.9 0-26.8-12-26.8-26.8s12-26.8 26.8-26.8 26.8 12 26.8 26.8zm76.1 27.2c-1.7-35.9-9.9-67.7-36.2-93.9-26.2-26.2-58-34.4-93.9-36.2-37-2.1-147.9-2.1-184.9 0-35.8 1.7-67.6 9.9-93.9 36.1s-34.4 58-36.2 93.9c-2.1 37-2.1 147.9 0 184.9 1.7 35.9 9.9 67.7 36.2 93.9s58 34.4 93.9 36.2c37 2.1 147.9 2.1 184.9 0 35.9-1.7 67.7-9.9 93.9-36.2 26.2-26.2 34.4-58 36.2-93.9 2.1-37 2.1-147.8 0-184.8zM398.8 388c-7.8 19.6-22.9 34.7-42.6 42.6-29.5 11.7-99.5 9-132.1 9s-102.7 2.6-132.1-9c-19.6-7.8-34.7-22.9-42.6-42.6-11.7-29.5-9-99.5-9-132.1s-2.6-102.7 9-132.1c7.8-19.6 22.9-34.7 42.6-42.6 29.5-11.7 99.5-9 132.1-9s102.7-2.6 132.1 9c19.6 7.8 34.7 22.9 42.6 42.6 11.7 29.5 9 99.5 9 132.1s2.7 102.7-9 132.1z',
    viewBox: '0 0 448 512',
  },
  {
    href: 'https://linkedin.com/', label: 'Linkedin',
    path: 'M100.28 448H7.4V148.9h92.88zM53.79 108.1C24.09 108.1 0 83.5 0 53.8a53.79 53.79 0 0 1 107.58 0c0 29.7-24.1 54.3-53.79 54.3zM447.9 448h-92.68V302.4c0-34.7-.7-79.2-48.29-79.2-48.29 0-55.69 37.7-55.69 76.7V448h-92.78V148.9h89.08v40.8h1.3c12.4-23.5 42.69-48.3 87.88-48.3 94 0 111.28 61.9 111.28 142.3V448z',
    viewBox: '0 0 448 512',
  },
];
---

<header transition:persist class="avh" data-header>
  {/* ── Desktop header ── */}
  <div class="avh__desktop">
    <div class="avh__logo-box">
      <a href="/" aria-label="Red Rocks Fire Protection home">
        <img
          src="/images/RRFPS_LOGO.png"
          alt="Red Rocks Fire Protection"
          class="avh__logo"
        />
      </a>
    </div>

    <div class="avh__right">
      <div class="avh__toprow">
        <div class="avh__socials">
          {socials.map((s) => (
            <a href={s.href} aria-label={s.label} class="avh__social" target="_blank" rel="noopener">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox={s.viewBox} fill="currentColor" aria-hidden="true">
                <path d={s.path}></path>
              </svg>
            </a>
          ))}
        </div>
        <h6 class="avh__hours">Mon - Sat: 7.00am - 19.00pm</h6>
      </div>

      <div class="avh__navrow">
        <nav aria-label="Primary" class="avh__nav">
          <ul>
            {navItems.map((item) => (
              <li class:list={['avh__item', item.children && 'avh__item--has-children']}>
                {item.children ? (
                  /* Dropdown trigger — button, not <a>, since it doesn't navigate */
                  <>
                    <button
                      type="button"
                      class:list={['avh__link', 'avh__link--trigger', isCurrent(item) && 'avh__link--current']}
                      aria-haspopup="menu"
                      aria-expanded="false"
                      data-dropdown-trigger
                      aria-current={isCurrent(item) ? 'page' : undefined}
                    >
                      <span>{item.label}</span>
                      <svg class="avh__caret" width="10" height="6" viewBox="0 0 10 6" aria-hidden="true">
                        <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </button>
                    <ul class="avh__submenu" role="menu" data-dropdown-menu>
                      {item.children.map((child) => {
                        const isChildCurrent = currentPath === child.href || currentPath.startsWith(child.href + '/');
                        return (
                          <li role="none">
                            <a
                              href={child.href}
                              role="menuitem"
                              class:list={['avh__sublink', isChildCurrent && 'avh__sublink--current']}
                              aria-current={isChildCurrent ? 'page' : undefined}
                            >
                              {child.label}
                            </a>
                          </li>
                        );
                      })}
                    </ul>
                  </>
                ) : (
                  <a
                    href={item.href}
                    class:list={['avh__link', isCurrent(item) && 'avh__link--current']}
                    aria-current={isCurrent(item) ? 'page' : undefined}
                  >
                    {item.label}
                  </a>
                )}
              </li>
            ))}
          </ul>
        </nav>

        <div class="avh__tools">
          <button type="button" class="avh__tool avh__search" aria-label="Search">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>

  {/* ── Mobile header ── */}
  <div class="avh__mobile">
    <a href="/" aria-label="Red Rocks Fire Protection home">
      <img
        src="/images/RRFPS_LOGO.png"
        alt="Red Rocks Fire Protection"
        class="avh__logo avh__logo--mobile"
      />
    </a>
    <button
      type="button"
      class="avh__burger"
      aria-label="Open menu"
      aria-expanded="false"
      data-menu-trigger
    >
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M2 5h16M2 10h16M2 15h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  {/* Mobile drawer */}
  <div class="avh__drawer" data-menu-overlay aria-hidden="true">
    <nav aria-label="Mobile primary">
      <ul>
        {navItems.map((item) => (
          <li>
            {item.children ? (
              /* Mobile: parent is a non-navigating header, children indented. */
              <>
                <span class="avh__drawer-parent">{item.label}</span>
                <ul class="avh__drawer-sub">
                  {item.children.map((child) => (
                    <li>
                      <a
                        href={child.href}
                        class:list={[
                          currentPath === child.href && 'avh__drawer-link--current',
                        ]}
                        aria-current={currentPath === child.href ? 'page' : undefined}
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </>
            ) : (
              <a href={item.href} aria-current={isCurrent(item) ? 'page' : undefined}>{item.label}</a>
            )}
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .avh {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: transparent;
  }

  /* ── Desktop ── */
  .avh__desktop {
    display: none;
  }
  @media (min-width: 1025px) {
    .avh__desktop {
      display: flex;
      align-items: stretch;
      border-bottom: 1px solid #ffffff66;
    }
  }
  .avh__logo-box {
    width: max(251px, 16.1%);
    flex-shrink: 0;
    background-color: #d41226;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: -1px;
  }
  .avh__logo {
    height: 77px;
    width: auto;
    display: block;
  }
  .avh__right {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .avh__toprow {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 39px;
    padding-left: 4%;
    padding-right: 5.6%;
  }
  .avh__socials {
    display: flex;
    align-items: center;
  }
  .avh__social {
    color: #ffffff;
    display: inline-flex;
    transition: 0.4s;
  }
  .avh__social:not(:last-child) { margin-right: 20px; }
  .avh__social:hover { color: #ffffff99; }
  .avh__social svg { width: 18px; height: 18px; }
  .avh__hours {
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: 16px;
    line-height: 30px;
    letter-spacing: -0.02em;
    color: #ffffff;
    margin: 0;
  }
  .avh__navrow {
    display: flex;
    align-items: center;
    border-top: 1px solid #ffffff66;
    padding-left: 2.9%;
    padding-right: 5.6%;
  }
  .avh__nav { flex: 1; }
  .avh__nav ul {
    display: flex;
    align-items: center;
    height: 94px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* Each top-level nav item is a positioned <li>; dropdowns hang off it. */
  .avh__item {
    position: relative;
    display: flex;
    align-items: center;
    height: 100%;
  }

  .avh__link {
    display: flex;
    align-items: center;
    height: 100%;
    margin: 0 20px;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: 16px;
    line-height: 30px;
    color: #ffffff;
    text-decoration: none;
    transition: 0.5s ease-in-out;
    background: none;
    border: 0;
    padding: 0;
    cursor: pointer;
    font: inherit; /* button reset; keep nav typography */
    font-weight: 700;
    font-size: 16px;
    letter-spacing: 0;
  }
  /* buttons should still match anchor line-height / color rules */
  button.avh__link { line-height: 30px; color: #ffffff; }

  .avh__nav li:first-child .avh__link { margin-left: 0; }
  .avh__link:hover,
  .avh__link--current { color: #d41226; }

  /* Caret + spacing inside the trigger */
  .avh__link--trigger { gap: 8px; }
  .avh__caret {
    transition: transform 250ms ease;
  }
  .avh__item--has-children.is-open .avh__caret { transform: rotate(180deg); }

  /* ── Submenu (desktop) ────────────────────────────────────────
   * Hidden by default; revealed on hover of the parent <li>, OR on
   * focus-within (keyboard nav), OR when JS has added `is-open`
   * via the trigger click. Anchored to the bottom of the parent.
   *
   * Vertical-list layout: a simple single-column stack, one item
   * per row, reading top-to-bottom. No grid columns, no horizontal
   * rows — items 1, 2, 3, … stack vertically. Each list item is
   * its own line.
   *
   * The panel is a flex column itself so its <li> children stack
   * vertically. `width: max-content` makes the panel hug the widest
   * child, while `max-width: 320px` caps it before the panel starts
   * eating horizontal space on the page. */
  .avh__submenu {
    position: absolute;
    top: 100%;
    left: 0;
    width: max-content;
    max-width: 320px;
    display: flex;
    flex-direction: column;
    margin: 0;
    padding: 10px 0;
    list-style: none;
    background: #D31126;          /* red panel — all dropdown menus */
    box-shadow: 0 10px 24px rgba(0,0,0,0.25);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition: opacity 200ms ease, transform 200ms ease, visibility 200ms;
    z-index: 50;
  }
  /* Each <li> inside the submenu is just a normal block — no flex on
     the list items themselves, so they don't introduce horizontal gaps. */
  .avh__submenu > li { width: 100%; display: block; }

  /* Open on hover, focus-within, or programmatic .is-open */
  .avh__item--has-children:hover > .avh__submenu,
  .avh__item--has-children:focus-within > .avh__submenu,
  .avh__item--has-children.is-open > .avh__submenu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  /* Hovering the trigger button keeps the menu open */
  .avh__link--trigger:hover + .avh__submenu,
  .avh__link--trigger:focus-visible + .avh__submenu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .avh__sublink {
    display: block;
    width: 100%;
    box-sizing: border-box;
    padding: 12px 22px;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: 14px;
    line-height: 20px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #ffffff;
    text-decoration: none;
    background-color: #D31126;    /* each item is a colored row matching the panel */
    transition: background 150ms ease, color 150ms ease;
    white-space: nowrap;
  }
  .avh__sublink:hover {
    /* darker red on hover so the active affordance reads against the new base */
    background-color: #a70d1e;
    color: #ffffff;
  }
  /* Currently-active item gets a brighter top edge so the user sees
     where they are inside the dropdown. Replaces the prior subtle
     white-tint, which read as "missing" against the red rows. */
  .avh__sublink--current {
    background-color: #D31126;
    box-shadow: inset 4px 0 0 0 #ffffff;
  }
  .avh__sublink--current:hover {
    background-color: #a70d1e;
  }

  .avh__tools {
    display: flex;
    align-items: center;
  }
  .avh__tool {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: 16px;
    color: #ffffff;
    text-transform: uppercase;
    text-decoration: none;
    transition: 0.4s;
  }
  .avh__tool:hover { color: #ffffff99; }
  .avh__cart { margin-right: 43px; }

  /* ── Mobile ── */
  .avh__mobile {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 70px;
    padding: 0 15px;
  }
  @media (min-width: 1025px) {
    .avh__mobile { display: none; }
  }
  .avh__logo--mobile { height: 36px; }
  .avh__burger {
    width: 50px;
    height: 50px;
    border-radius: 50px;
    color: #181818;
    background: #ffffff;
    border: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  /* ── Drawer ── */
  .avh__drawer {
    display: none;
    background: #0d0d0b;
    padding: 20px 15px 40px;
  }
  .avh__drawer.is-open { display: block; }
  .avh__drawer > nav > ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .avh__drawer > nav > ul > li {
    border-bottom: 1px solid #ffffff1a;
  }
  .avh__drawer a {
    display: block;
    padding: 12px 0;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: 18px;
    color: #ffffff;
    text-decoration: none;
  }
  .avh__drawer a:hover { color: #d41226; }

  /* Parent label (Services) — non-navigating heading in mobile drawer */
  .avh__drawer-parent {
    display: block;
    padding: 12px 0;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: 18px;
    color: #ffffff;
    opacity: 0.55;
    letter-spacing: 0.04em;
  }
  .avh__drawer-sub {
    list-style: none;
    margin: 0 0 8px 16px;
    padding: 0 0 8px 0;
    border-left: 1px solid #ffffff1f;
  }
  .avh__drawer-sub a {
    padding: 8px 0 8px 14px;
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 0.04em;
  }
  .avh__drawer-link--current {
    color: #D31126 !important;
  }
</style>

<script>
  function initMobileMenu() {
    const trigger = document.querySelector('[data-menu-trigger]');
    const overlay = document.querySelector('[data-menu-overlay]');
    if (!trigger || !overlay) return;

    let open = false;
    trigger.addEventListener('click', () => {
      open = !open;
      overlay.classList.toggle('is-open', open);
      overlay.setAttribute('aria-hidden', String(!open));
      trigger.setAttribute('aria-expanded', String(open));
    });
  }

  /**
   * Dropdown behavior — runs alongside initMobileMenu but is independent.
   * On desktop, hover opens natively (CSS). On touch devices without
   * hover, click the trigger to toggle. Outside-click closes. Esc closes.
   */
  function initDropdowns() {
    const items = Array.from(document.querySelectorAll<HTMLElement>('.avh__item--has-children'));
    if (!items.length) return;

    const isCoarse = window.matchMedia('(hover: none)').matches;

    items.forEach((item) => {
      const button = item.querySelector<HTMLButtonElement>('[data-dropdown-trigger]');
      const menu = item.querySelector<HTMLElement>('[data-dropdown-menu]');
      if (!button || !menu) return;

      const open = () => {
        // Close any sibling dropdowns first
        items.forEach((other) => {
          if (other !== item) {
            other.classList.remove('is-open');
            other.querySelector<HTMLButtonElement>('[data-dropdown-trigger]')?.setAttribute('aria-expanded', 'false');
          }
        });
        item.classList.add('is-open');
        button.setAttribute('aria-expanded', 'true');
      };
      const close = () => {
        item.classList.remove('is-open');
        button.setAttribute('aria-expanded', 'false');
      };
      const toggle = () => {
        if (item.classList.contains('is-open')) close();
        else open();
      };

      // Touch/click — always wire so keyboard users + coarse pointer can open.
      button.addEventListener('click', (e) => {
        e.preventDefault();
        toggle();
      });

      // Keyboard — Enter / Space already triggers click; Escape closes from item.
      button.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') close();
      });
      item.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          close();
          button.focus();
        }
      });

      // On coarse pointers (touch), also prevent CSS-only hover-open from
      // getting stuck open after a tap elsewhere.
      if (isCoarse) {
        // close on blur when focus leaves the whole subtree
        item.addEventListener('focusout', (e) => {
          const next = e.relatedTarget as Node | null;
          if (!next || !item.contains(next)) close();
        });
      }
    });

    // Outside click closes any open dropdown
    document.addEventListener('click', (e) => {
      const target = e.target as Node;
      items.forEach((item) => {
        if (!item.contains(target)) {
          item.classList.remove('is-open');
          item.querySelector<HTMLButtonElement>('[data-dropdown-trigger]')?.setAttribute('aria-expanded', 'false');
        }
      });
    });
    // Esc at top level also closes any open dropdown
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        items.forEach((item) => {
          item.classList.remove('is-open');
          item.querySelector<HTMLButtonElement>('[data-dropdown-trigger]')?.setAttribute('aria-expanded', 'false');
        });
      }
    });
  }

  function initAll() {
    initMobileMenu();
    initDropdowns();
  }
  document.addEventListener('astro:page-load', initAll);
  if (document.readyState !== 'loading') initAll();
</script>

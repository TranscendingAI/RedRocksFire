---
/**
 * DualCTA — design.md §4.8
 *
 * Two large uppercase titles side by side, divided by a vertical rule.
 * Each has a small descriptor and an outbound corner arrow (↗).
 * Designed for a black band.
 */

interface CtaItem {
  title: string;
  descriptor: string;
  href: string;
  label: string;
}

interface Props {
  items: [CtaItem, CtaItem];
  background?: 'black' | 'light' | 'white';
}

const { items, background = 'black' } = Astro.props;
const bgClass =
  background === 'black' ? 'bg-rr-black text-rr-white'
  : background === 'white' ? 'bg-rr-white text-rr-black'
  : 'bg-rr-bg-light text-rr-black';
const descriptorClass = background === 'black' ? 'text-rr-grey-soft' : 'text-rr-grey';
const divideClass = background === 'black' ? 'md:divide-white/10' : 'md:divide-black/10';
---

<section class:list={['rr-band', bgClass]}>
  <div class="rr-container">
    <div class:list={['grid gap-12 md:grid-cols-2 md:gap-0 md:divide-x', divideClass]}>
      {items.map((item, i) => (
        <a
          href={item.href}
          class:list={[
            'group block relative',
            i === 0 ? 'md:pr-12 lg:pr-16' : 'md:pl-12 lg:pl-16',
          ]}
        >
          {/* Corner arrow */}
          <span
            class="absolute top-0 right-0 text-2xl md:text-3xl transition-transform duration-150 group-hover:-translate-y-1 group-hover:translate-x-1"
            aria-hidden="true"
          >
            ↗
          </span>

          <h3
            class="font-display font-black uppercase tracking-tight"
            style="font-size: var(--rr-text-statement); line-height: 0.95;"
          >
            {item.title}
          </h3>
          <p class:list={['mt-5 max-w-md', descriptorClass]} style="font-size: var(--rr-text-lead);">
            {item.descriptor}
          </p>
          <div class="mt-6 text-sm font-semibold uppercase tracking-wider opacity-70 group-hover:opacity-100 transition-opacity">
            {item.label} →
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
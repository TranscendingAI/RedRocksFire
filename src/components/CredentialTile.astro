---
/**
 * CredentialTile — design.md §4.5 (credential / logo tile)
 *
 * Translucent tile with thin white border. Used in a grid on a photo band.
 * Background lets the underlying photo show through (frosted-glass effect).
 */
interface Props {
  label: string;
  detail?: string;
}

const { label, detail } = Astro.props;
---

<div class="bg-white/10 border border-white/30 rounded-rr-card aspect-square flex flex-col items-center justify-center p-6 text-center">
  <div class="font-display font-black uppercase text-rr-white text-2xl md:text-3xl tracking-tight leading-none">
    {label}
  </div>
  {detail && (
    <div class="mt-3 text-xs uppercase tracking-widest text-rr-grey-soft font-semibold">
      {detail}
    </div>
  )}
</div>
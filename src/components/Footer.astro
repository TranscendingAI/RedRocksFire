---

<footer class="avf">
  <div class="avf__spacer-top" aria-hidden="true"></div>
  <div class="avf__divider" aria-hidden="true"></div>

  <div class="avf__main">
    <div class="avf__contact">
      <h3 class="avf__col-heading">get in touch</h3>
      <a href="mailto:info@rrfps.com" class="avf__big-link">info@rrfps.com</a>
      <a href="tel:+17207338050" class="avf__big-link avf__big-link--phone">(720) 733-8050</a>
      <div class="avf__contact-spacer" aria-hidden="true"></div>
      <div class="avf__socials">
        {socials.map((s) => (
          <a href={s.href} aria-label={s.label} class="avf__social" target="_blank" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox={s.viewBox} fill="currentColor" aria-hidden="true">
              <path d={s.path}></path>
            </svg>
          </a>
        ))}
      </div>
    </div>

    <div class="avf__col">
      <h3 class="avf__col-heading">company</h3>
      <ul class="avf__links">
        {companyLinks.map((label) => (
          <li><a href="/contact" class="avf__link">{label}</a></li>
        ))}
      </ul>
    </div>

    <div class="avf__col">
      <h3 class="avf__col-heading">services</h3>
      <ul class="avf__links">
        {serviceLinks.map((label) => (
          <li><a href="/contact" class="avf__link">{label}</a></li>
        ))}
      </ul>
    </div>
  </div>

  <div class="avf__spacer-mid" aria-hidden="true"></div>
  <div class="avf__divider" aria-hidden="true"></div>
  <div class="avf__spacer-small" aria-hidden="true"></div>

  <p class="avf__copyright">© 2026 Red Rocks Fire Protection. All Rights Reserved</p>

  <div class="avf__divider" aria-hidden="true"></div>

  <h3 class="avf__giant" aria-hidden="true">
    <span>Red Rocks </span><span>Fire Protection</span>
  </h3>
  <div class="avf__spacer-bottom" aria-hidden="true"></div>
</footer>

<style>
  .avf {
    background-color: #0d0d0b;
    background-image: url('/images/home/footer-bg.webp');
    background-position: center center;
    background-size: cover;
    overflow: hidden;
  }
  .avf__spacer-top { height: 99px; }
  .avf__spacer-mid { height: 77px; }
  .avf__spacer-small { height: 30px; }
  .avf__spacer-bottom { height: 84px; }
  .avf__divider { border-top: 1px solid #ffffff66; }

  .avf__main {
    display: flex;
    gap: 30px;
    margin: -1px 0;
  }
  .avf__contact {
    width: 42.5%;
    background-color: #d41226;
    padding: 78px 67px 30px;
    box-sizing: border-box;
  }
  .avf__col {
    flex: 1;
    padding-top: 78px;
  }
  .avf__col-heading {
    margin: 0;
    font-size: 20px;
    text-transform: uppercase;
    line-height: 1em;
    color: #ffffff;
  }
  .avf__big-link {
    display: inline-block;
    margin-top: 31px;
    font-family: "Space Grotesk", sans-serif;
    font-size: 36px;
    font-weight: 700;
    line-height: 1em;
    letter-spacing: -0.04em;
    color: #ffffff;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: 0.4s;
  }
  .avf__big-link--phone { display: block; margin-top: 18px; }
  .avf__big-link:hover { border-bottom-color: #ffffff; }
  .avf__contact-spacer { height: 52px; }
  .avf__socials { display: flex; }
  .avf__social {
    color: #ffffff;
    display: inline-flex;
    transition: 0.4s;
  }
  .avf__social:not(:last-child) { margin-right: 22px; }
  .avf__social:hover { color: #ffffff66; }

  .avf__links {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .avf__link {
    display: inline-block;
    margin-top: 19px;
    font-family: "Space Grotesk", sans-serif;
    font-size: 16px;
    font-weight: 600;
    line-height: 1em;
    color: #ffffff;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: 0.4s;
  }
  .avf__link:hover { border-bottom-color: #ffffff; }

  .avf__copyright {
    margin: 0 0 30px;
    padding-left: 15px;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    color: #ffffff;
  }

  .avf__giant {
    margin: 0;
    text-align: center;
    /* Responsive font: scales smoothly between 48px (small phones)
     * and 180px (≥1400px viewports). vw term lets it grow continuously
     * with viewport width instead of jumping at breakpoints. */
    font-size: clamp(48px, 13vw, 180px);
    text-transform: uppercase;
    line-height: 0.85em;
    letter-spacing: -0.04em;
    padding: 0 8px 5px;
    background-image: linear-gradient(180deg, #ffffff00 0%, #ffffff 76%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    overflow-wrap: break-word;
  }
  .avf__giant span { white-space: nowrap; }

  @media (max-width: 1200px) {
    .avf__spacer-top { height: 30px; }
    .avf__spacer-mid { height: 40px; }
    .avf__spacer-bottom { height: 20px; }
    .avf__contact { width: 37%; padding: 50px 40px 30px; }
    .avf__big-link { font-size: 28px; }
  }
  @media (max-width: 767px) {
    .avf__main { flex-wrap: wrap; gap: 40px; }
    .avf__contact { width: 100%; padding: 40px 20px 30px; }
    .avf__col { padding-top: 0; padding-left: 20px; }
    .avf__contact-spacer { height: 30px; }
    /* .avf__giant font-size is now handled by clamp() in the base rule. */
  }
</style>

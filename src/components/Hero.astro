---
/**
 * Hero — design.md §4.4 (modified)
 *
 * Two layouts supported:
 *   A. Default: 2-column split, light background — title + subcopy + CTA on
 *      left, optional image on right. Both columns vertically centered.
 *   B. With backgroundImage: full-bleed background photo + dark overlay
 *      (legacy, kept for future use).
 */
import Button from './Button.astro';

interface Props {
  title: string;
  highlight?: string;
  subtitle?: string;
  ctaLabel?: string;
  ctaHref?: string;
  backgroundImage?: string;
  image?: string;
  imageAlt?: string;
}

const {
  title,
  highlight,
  subtitle,
  ctaLabel = 'Schedule Our Services',
  ctaHref = '/contact',
  backgroundImage,
  image,
  imageAlt = '',
} = Astro.props;

const isSplitLayout = !!image && !backgroundImage;

let titleBefore = '';
let titleAfter = title;
if (highlight) {
  const idx = title.toLowerCase().indexOf(highlight.toLowerCase());
  if (idx !== -1) {
    titleBefore = title.slice(0, idx).trimEnd();
    titleAfter = title.slice(idx + highlight.length).trimStart();
  }
}
---

<section
  class="relative w-full overflow-hidden"
  style={`min-height: 100svh; background: #F4F2F1;`}
>
  {/* Background image — only if explicitly passed (legacy dark hero) */}
  {backgroundImage && (
    <>
      <div
        class="absolute inset-0 bg-rr-bg-panel"
        style={`background-image: url('${backgroundImage}'); background-size: cover; background-position: center;`}
        aria-hidden="true"
      />
      <div class="absolute inset-0" style="background: var(--rr-overlay);" aria-hidden="true"></div>
    </>
  )}

  {isSplitLayout ? (
    <div class="relative z-10 rr-container grid items-center gap-10 md:gap-16 lg:grid-cols-2 py-20 md:py-28 min-h-[100svh]">
      {/* Left: text + CTA */}
      <div class="max-w-2xl">
        <h1
          class="font-display font-black uppercase text-rr-black tracking-tight"
          style="font-size: 65px; line-height: 0.95; letter-spacing: -0.02em;"
        >
          {highlight ? (
            <>
              {titleBefore}
              {titleBefore && <br/>}
              <span class="text-rr-red">{highlight}</span>
              {titleAfter && <br/>}
              {titleAfter}
            </>
          ) : (
            title
          )}
        </h1>

        {subtitle && (
          <p
            class="mt-8 max-w-xl text-rr-grey rr-reveal"
            style="font-size: var(--rr-text-lead);"
            data-reveal-delay="200"
          >
            {subtitle}
          </p>
        )}

        {ctaLabel && (
          <div class="mt-10 rr-reveal" data-reveal-delay="400">
            <Button href={ctaHref} variant="primary" band="light" size="lg">
              {ctaLabel}
            </Button>
          </div>
        )}
      </div>

      {/* Right: image */}
      <div class="rr-reveal" data-reveal-delay="200">
        <img
          src={image}
          alt={imageAlt}
          class="w-full h-auto max-h-[80svh] object-contain"
          loading="eager"
          decoding="async"
        />
      </div>
    </div>
  ) : (
    /* Legacy layout: text only, vertically bottom-aligned */
    <div class="relative z-10 rr-container flex flex-col justify-end pb-16 md:pb-24 pt-32 md:pt-40 min-h-[100svh]">
      <div class="max-w-4xl">
        <h1
          class="font-display font-black uppercase tracking-tight"
          style={`font-size: 65px; line-height: 0.95; letter-spacing: -0.02em; color: ${backgroundImage ? 'var(--rr-white)' : 'var(--rr-black)'};`}
        >
          {highlight ? (
            <>
              {titleBefore}
              {titleBefore && <br/>}
              <span class="text-rr-red">{highlight}</span>
              {titleAfter && <br/>}
              {titleAfter}
            </>
          ) : (
            title
          )}
        </h1>

        {subtitle && (
          <p
            class="mt-8 max-w-2xl rr-reveal"
            style="font-size: var(--rr-text-lead);"
            data-reveal-delay="200"
          >
            {subtitle}
          </p>
        )}

        {ctaLabel && (
          <div class="mt-10 rr-reveal" data-reveal-delay="400">
            <Button href={ctaHref} variant="primary" band={backgroundImage ? 'dark' : 'light'} size="lg">
              {ctaLabel}
            </Button>
          </div>
        )}
      </div>
    </div>
  )}
</section>
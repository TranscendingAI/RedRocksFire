---
/**
 * ServiceCard — design.md §4.5 (standard content card)
 *
 * Image top, white body below. Title (display 700), body copy, arrow CTA.
 */
import Button from './Button.astro';

interface Props {
  title: string;
  body: string;
  image: string;
  imageAlt: string;
  ctaHref?: string;
}

const { title, body, image, imageAlt, ctaHref = '/services' } = Astro.props;
---

<article class="group flex-shrink-0 w-[85vw] sm:w-[60vw] md:w-[calc((100%-3rem)/2.5)] lg:w-[calc((100%-3rem)/3)] bg-rr-white border border-rr-border-lt rounded-rr-card overflow-hidden transition-transform duration-150 hover:-translate-y-1 hover:shadow-xl">
  <div class="aspect-[4/3] overflow-hidden bg-rr-bg-panel">
    <img
      src={image}
      alt={imageAlt}
      loading="lazy"
      decoding="async"
      class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
    />
  </div>
  <div class="p-7">
    <h3
      class="font-display font-bold tracking-tight"
      style="font-size: var(--rr-text-card); line-height: 1.05;"
    >
      {title}
    </h3>
    <p class="mt-3 text-sm text-rr-grey leading-relaxed">{body}</p>
    <div class="mt-5">
      <Button href={ctaHref} variant="arrow" band="light" size="md">
        More details
      </Button>
    </div>
  </div>
</article>